{%- comment -%}
  ============================================================
  YumBud · Newsletter (Online Store 2.0)
  Dark band with a REAL working email signup (Shopify customer form).
  Submitted emails appear under Customers (tagged "newsletter").
  ============================================================
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-fg:{{ s.text_color }}; --yb-muted:{{ s.muted_color }};
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  .yb-n-{{ uid }}{ background:var(--yb-bg); color:var(--yb-fg); text-align:center; padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  .yb-n-in-{{ uid }}{ max-width:1280px; margin:0 auto; padding:0 40px; }
  .yb-n-eyebrow-{{ uid }}{ font-size:11px; letter-spacing:.28em; text-transform:uppercase; color:var(--yb-muted); font-weight:500; margin-bottom:18px; }
  .yb-n-{{ uid }} h2{ font-family:var(--yb-serif); font-weight:500; line-height:1.05; color:var(--yb-fg); font-size:clamp(30px,3.8vw,50px); margin-bottom:14px; }
  .yb-n-{{ uid }} p{ color:var(--yb-muted); font-size:15px; font-weight:300; margin-bottom:34px; }
  .yb-n-form-{{ uid }}{ display:flex; max-width:480px; margin:0 auto; border-bottom:1px solid {{ s.text_color }}52; }
  .yb-n-form-{{ uid }} input[type=email]{ flex:1; background:none; border:none; color:var(--yb-fg); font-size:15px; padding:14px 4px; outline:none; font-family:inherit; }
  .yb-n-form-{{ uid }} input::placeholder{ color:var(--yb-muted); }
  .yb-n-form-{{ uid }} button{ font-size:11px; letter-spacing:.16em; text-transform:uppercase; font-weight:600; color:var(--yb-fg); padding:14px 8px; background:none; border:none; cursor:pointer; transition:.3s; }
  .yb-n-form-{{ uid }} button:hover{ letter-spacing:.22em; }
  .yb-n-note-{{ uid }}{ display:block; margin-top:18px; font-size:10.5px; letter-spacing:.14em; text-transform:uppercase; color:var(--yb-muted); }
  .yb-n-ok-{{ uid }}{ margin-top:18px; color:var(--yb-fg); font-size:14px; }
</style>

<section class="yb-n-{{ uid }}">
  <div class="yb-n-in-{{ uid }}">
    {% if s.eyebrow != blank %}<div class="yb-n-eyebrow-{{ uid }}">{{ s.eyebrow }}</div>{% endif %}
    {% if s.heading != blank %}<h2>{{ s.heading }}</h2>{% endif %}
    {% if s.body != blank %}<p>{{ s.body }}</p>{% endif %}

    {% form 'customer' %}
      {% if form.posted_successfully? %}
        <p class="yb-n-ok-{{ uid }}">{{ s.success_text }}</p>
      {% else %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="yb-n-form-{{ uid }}">
          <input type="email" name="contact[email]" placeholder="{{ s.placeholder }}" required>
          <button type="submit">{{ s.button_label }} &rarr;</button>
        </div>
      {% endif %}
    {% endform %}

    {% if s.note != blank %}<small class="yb-n-note-{{ uid }}">{{ s.note }}</small>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "YumBud · Newsletter",
  "tag": "section",
  "class": "yumbud-newsletter-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the pantry list" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A little more, now and then." },
    { "type": "text", "id": "body", "label": "Body", "default": "New recipes, restocks and the occasional good-dog story. No noise." },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Your email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" },
    { "type": "text", "id": "success_text", "label": "Success message", "default": "Thank you — you're on the list." },
    { "type": "text", "id": "note", "label": "Small print", "default": "We send rarely · Unsubscribe anytime" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#211D18" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F4EFE6" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#A59E90" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 104 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 104 }
  ],
  "presets": [ { "name": "YumBud · Newsletter" } ]
}
{% endschema %}
