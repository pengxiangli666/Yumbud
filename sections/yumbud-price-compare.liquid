{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-muted:{{ s.muted_color }};
    --yb-accent:{{ s.accent_color }}; --yb-card:{{ s.card_color }};
    --yb-line:{{ s.text_color }}1f;
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  .yb-pc-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  .yb-pc-wrap-{{ uid }}{ max-width:1080px; margin:0 auto; padding:0 40px; text-align:center; }
  .yb-pc-eyebrow-{{ uid }}{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-muted); margin-bottom:14px; }
  .yb-pc-{{ uid }} h2{ font-family:var(--yb-serif); font-size:clamp(28px,3.6vw,42px); font-weight:500; line-height:1.1; margin-bottom:18px; }
  .yb-pc-sub-{{ uid }}{ font-size:15px; color:var(--yb-muted); max-width:560px; margin:0 auto 50px; line-height:1.6; }
  .yb-pc-cards-{{ uid }}{ display:grid; grid-template-columns:1fr 1fr; gap:20px; text-align:left; }
  .yb-pc-card-{{ uid }}{ background:var(--yb-card); border-radius:12px; padding:36px 32px; position:relative; }
  .yb-pc-card-{{ uid }}.featured{ background:var(--yb-ink); color:var(--yb-bg); }
  .yb-pc-card-{{ uid }} .tag{ position:absolute; top:20px; right:20px; background:var(--yb-accent); color:#fff; padding:5px 12px; border-radius:20px; font-size:10px; letter-spacing:.12em; text-transform:uppercase; }
  .yb-pc-card-{{ uid }} .nm{ font-size:14px; letter-spacing:.14em; text-transform:uppercase; margin-bottom:18px; opacity:.7; }
  .yb-pc-card-{{ uid }} .pr{ font-family:var(--yb-serif); font-size:46px; font-weight:500; line-height:1; margin-bottom:6px; }
  .yb-pc-card-{{ uid }} .pr .per{ font-size:14px; opacity:.6; margin-left:4px; }
  .yb-pc-card-{{ uid }} .desc{ font-size:14px; opacity:.75; margin-bottom:24px; line-height:1.5; }
  .yb-pc-feats-{{ uid }}{ list-style:none; padding:0; margin:0 0 28px; }
  .yb-pc-feats-{{ uid }} li{ padding:9px 0; font-size:14px; border-bottom:1px solid currentColor; opacity:.85; display:flex; align-items:center; gap:10px; }
  .yb-pc-feats-{{ uid }} li:last-child{ border-bottom:none; }
  .yb-pc-feats-{{ uid }} li .ic{ width:16px; height:16px; flex:none; }
  @media (max-width:760px){
    .yb-pc-cards-{{ uid }}{ grid-template-columns:1fr; }
    .yb-pc-wrap-{{ uid }}{ padding:0 24px; }
  }
</style>

<section class="yb-pc-{{ uid }}">
  <div class="yb-pc-wrap-{{ uid }}">
    {% if s.eyebrow != blank %}<div class="yb-pc-eyebrow-{{ uid }}">{{ s.eyebrow }}</div>{% endif %}
    {% if s.heading != blank %}<h2>{{ s.heading }}</h2>{% endif %}
    {% if s.body != blank %}<div class="yb-pc-sub-{{ uid }}">{{ s.body }}</div>{% endif %}

    <div class="yb-pc-cards-{{ uid }}">
      <div class="yb-pc-card-{{ uid }}">
        <div class="nm">{{ s.left_title }}</div>
        <div class="pr">{{ s.left_price }}<span class="per">{{ s.left_per }}</span></div>
        <div class="desc">{{ s.left_desc }}</div>
        <ul class="yb-pc-feats-{{ uid }}">
          {% for block in section.blocks %}{% if block.type == 'left_feature' %}
            <li><span class="ic">○</span>{{ block.settings.text }}</li>
          {% endif %}{% endfor %}
        </ul>
      </div>
      <div class="yb-pc-card-{{ uid }} featured">
        {% if s.right_badge != blank %}<span class="tag">{{ s.right_badge }}</span>{% endif %}
        <div class="nm">{{ s.right_title }}</div>
        <div class="pr">{{ s.right_price }}<span class="per">{{ s.right_per }}</span></div>
        <div class="desc">{{ s.right_desc }}</div>
        <ul class="yb-pc-feats-{{ uid }}">
          {% for block in section.blocks %}{% if block.type == 'right_feature' %}
            <li><span class="ic">✓</span>{{ block.settings.text }}</li>
          {% endif %}{% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "YumBud · Price Compare",
  "tag": "section",
  "class": "yumbud-price-compare",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Smart Pricing" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Subscribe and save 20%" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Same great food, lower price, delivered automatically.</p>" },
    { "type": "header", "content": "Left card (One-time)" },
    { "type": "text", "id": "left_title", "label": "Title", "default": "One-time" },
    { "type": "text", "id": "left_price", "label": "Price", "default": "$36" },
    { "type": "text", "id": "left_per", "label": "Per unit", "default": "/ bag" },
    { "type": "text", "id": "left_desc", "label": "Description", "default": "Buy once, no commitment." },
    { "type": "header", "content": "Right card (Subscribe)" },
    { "type": "text", "id": "right_badge", "label": "Badge", "default": "Best value" },
    { "type": "text", "id": "right_title", "label": "Title", "default": "Subscribe & Save" },
    { "type": "text", "id": "right_price", "label": "Price", "default": "$28" },
    { "type": "text", "id": "right_per", "label": "Per unit", "default": "/ bag" },
    { "type": "text", "id": "right_desc", "label": "Description", "default": "Save 20% on every delivery. Cancel anytime." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FAF8F3" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#8C8578" },
    { "type": "color", "id": "accent_color", "label": "Badge", "default": "#2E3D2A" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#EDEAE0" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    { "type": "left_feature", "name": "Left feature", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Full price" }
    ] },
    { "type": "right_feature", "name": "Right feature", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "20% off every order" }
    ] }
  ],
  "presets": [
    { "name": "YumBud · Price Compare", "blocks": [
      { "type": "left_feature", "settings": { "text": "Full price" } },
      { "type": "left_feature", "settings": { "text": "Standard shipping" } },
      { "type": "left_feature", "settings": { "text": "Order again manually" } },
      { "type": "right_feature", "settings": { "text": "20% off every order" } },
      { "type": "right_feature", "settings": { "text": "Free shipping over $48" } },
      { "type": "right_feature", "settings": { "text": "Skip, swap, or cancel anytime" } },
      { "type": "right_feature", "settings": { "text": "Member-only flavours" } }
    ] }
  ]
}
{% endschema %}