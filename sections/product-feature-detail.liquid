{% comment %}
  Product Feature Detail Section - Premium Style
  Designed for YumBud's "No Chemistry Degree" Brand Identity
{% endcomment %}

<style>
  .pfd-section {
    background-color: {{ section.settings.bg_color }};
    padding: 80px 20px;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
  }

  .pfd-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .pfd-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 120px;
    gap: 60px;
  }

  .pfd-row:nth-child(even) {
    flex-direction: row-reverse;
  }

  .pfd-image-wrapper {
    flex: 1;
    text-align: center;
  }

  .pfd-image-wrapper img {
    max-width: 100%;
    height: auto;
    border-radius: 20px;
    transition: transform 0.3s ease;
  }

  .pfd-image-wrapper img:hover {
    transform: scale(1.02);
  }

  .pfd-content-wrapper {
    flex: 1;
  }

  .pfd-hook {
    color: {{ section.settings.accent_color }};
    font-size: 14px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 10px;
    display: block;
  }

  .pfd-title {
    color: {{ section.settings.text_color }};
    font-size: 36px;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .pfd-description {
    color: {{ section.settings.text_color }};
    font-size: 17px;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 30px;
  }

  .pfd-highlights {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
  }

  .pfd-highlight-item {
    display: flex;
    align-items: center;
    font-size: 15px;
    color: {{ section.settings.text_color }};
    font-weight: 500;
  }

  .pfd-highlight-item::before {
    content: "✓";
    margin-right: 10px;
    color: {{ section.settings.accent_color }};
    font-weight: bold;
  }

  @media (max-width: 768px) {
    .pfd-row, .pfd-row:nth-child(even) {
      flex-direction: column;
      text-align: center;
      margin-bottom: 60px;
    }
    .pfd-highlights {
      grid-template-columns: 1fr;
      text-align: left;
      display: inline-block;
    }
  }
</style>

<section class="pfd-section">
  <div class="pfd-container">
    {% for block in section.blocks %}
      <div class="pfd-row" {{ block.shopify_attributes }}>
        
        <div class="pfd-image-wrapper">
          {% if block.settings.product_image != blank %}
            {{ block.settings.product_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        <div class="pfd-content-wrapper">
          <span class="pfd-hook">{{ block.settings.hook }}</span>
          <h2 class="pfd-title">{{ block.settings.title }}</h2>
          <p class="pfd-description">{{ block.settings.description }}</p>
          
          <ul class="pfd-highlights">
            {% assign highlights = block.settings.highlights | newline_to_br | split: '<br />' %}
            {% for item in highlights %}
              {% if item != blank %}
                <li class="pfd-highlight-item">{{ item }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>

      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Product Feature Detail",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F2F1EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#2D362E"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#8B9A46" 
    }
  ],
  "blocks": [
    {
      "type": "product_block",
      "name": "Product Detail",
      "settings": [
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "hook",
          "label": "Hook Text",
          "default": "Pure & Natural"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Premium Treat Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Detailed Description",
          "default": "Describe the magic of your product here..."
        },
        {
          "type": "textarea",
          "id": "highlights",
          "label": "Highlights (One per line)",
          "default": "Highlight 1\nHighlight 2\nHighlight 3\nHighlight 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Feature Detail",
      "blocks": [
        { "type": "product_block" },
        { "type": "product_block" }
      ]
    }
  ]
}
{% endschema %}
