{%- comment -%}
  YumBud · Hero — full background image version 1
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
<style>
  #shopify-section-{{ uid }}{
    --yb-ink:{{ s.text_color }}; --yb-muted:{{ s.muted_color }};
    --yb-accent:{{ s.accent_color }}; --yb-line:{{ s.text_color }}24;
    --yb-cream:#FAF8F3; --yb-linen:#E5E1D7;
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
    --yb-ease:cubic-bezier(.22,.61,.36,1);
    --yb-overlay:{{ s.overlay_opacity | divided_by: 100.0 }};
  }
  .yb-h-{{ uid }}{
    position:relative; overflow:hidden;
    min-height:{{ s.min_height }}px;
    padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px;
    display:flex; align-items:center;
    color:var(--yb-ink);
  }
  .yb-h-{{ uid }}::after{
    content:""; pointer-events:none;
    position:absolute; inset:{{ s.frame_inset }}px; z-index:10;
    border:{{ s.frame_width }}px solid {{ s.frame_color }};
    opacity:{{ s.frame_opacity | divided_by: 100.0 }};
  }
  .yb-h-bg-{{ uid }}{
    position:absolute; inset:0; z-index:0;
  }
  .yb-h-bg-{{ uid }} img{
    width:100%; height:100%; object-fit:cover; object-position:{{ s.image_position }};
    display:block;
  }
  .yb-h-overlay-{{ uid }}{
    position:absolute; inset:0; z-index:1;
    background:{{ s.overlay_color }}; opacity:var(--yb-overlay);
  }
  .yb-h-{{ uid }} .wrapx{
    position:relative; z-index:2;
    max-width:1280px; margin:0 auto; padding:0 40px;
    width:100%;
  }
  .yb-h-inner-{{ uid }}{
    max-width:{{ s.content_max_width }}px;
    margin-left:{{ s.content_offset_left }}px;
    margin-right:{{ s.content_offset_right }}px;
  }
  .yb-h-eyebrow-{{ uid }}{
    font-size:11px; letter-spacing:.28em; text-transform:uppercase;
    color:var(--yb-muted); font-weight:500; margin-bottom:26px;
  }
  .yb-h-{{ uid }} h1{
    font-family:var(--yb-serif); font-weight:500; line-height:1.04;
    letter-spacing:-.01em; font-size:clamp(46px,6.6vw,92px);
    margin-bottom:26px; color:var(--yb-ink);
  }
  .yb-h-{{ uid }} h1 em{ font-style:italic; color:var(--yb-accent); }
  .yb-h-sub-{{ uid }}{
    font-size:17px; color:var(--yb-muted); max-width:430px;
    margin-bottom:38px; font-weight:300; line-height:1.6;
  }
  .yb-h-cta-{{ uid }}{
    display:flex; gap:14px; flex-wrap:wrap;
  }
  .yb-btn-{{ uid }}{
    display:inline-flex; align-items:center; gap:.6em; font-size:12px;
    letter-spacing:.16em; text-transform:uppercase; font-weight:500;
    padding:15px 30px; border-radius:3px; transition:.4s var(--yb-ease); white-space:nowrap;
  }
  .yb-btn-fill-{{ uid }}{
    background:{% if s.btn1_transparent %}transparent{% else %}{{ s.btn1_bg }}{% endif %};
    color:{{ s.btn1_text }};
    border:2px solid {{ s.btn1_border }};
  }
  .yb-btn-fill-{{ uid }}:hover{ opacity:0.8; }
  .yb-btn-line-{{ uid }}{
    background:{% if s.btn2_transparent %}transparent{% else %}{{ s.btn2_bg }}{% endif %};
    color:{{ s.btn2_text }};
    border:2px solid {{ s.btn2_border }};
  }
  .yb-btn-line-{{ uid }}:hover{ opacity:0.8; }
  .yb-h-meta-{{ uid }}{
    margin-top:46px; display:flex; gap:34px; align-items:center;
  }
  .yb-h-meta-{{ uid }} .m b{
    display:block; font-family:var(--yb-serif); font-size:30px;
    font-weight:500; line-height:1;
  }
  .yb-h-meta-{{ uid }} .m span{
    font-size:10.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--yb-muted);
  }
  .yb-h-meta-{{ uid }} .vr{ width:1px; height:42px; background:var(--yb-line); }
  @media (max-width:880px){
    .yb-h-{{ uid }} .wrapx{ padding:0 24px; }
    .yb-h-inner-{{ uid }}{ max-width:100%; margin-left:0; margin-right:0; }
  }
</style>

<section class="yb-h-{{ uid }}">
  <div class="yb-h-bg-{{ uid }}">
    {% if s.bg_image != blank %}
      <img src="{{ s.bg_image | image_url: width: 3840 }}"
        srcset="{{ s.bg_image | image_url: width: 750 }} 750w,
                {{ s.bg_image | image_url: width: 1080 }} 1080w,
                {{ s.bg_image | image_url: width: 1440 }} 1440w,
                {{ s.bg_image | image_url: width: 1920 }} 1920w,
                {{ s.bg_image | image_url: width: 2560 }} 2560w,
                {{ s.bg_image | image_url: width: 3840 }} 3840w"
        sizes="100vw"
        alt="{{ s.bg_image.alt | escape }}"
        loading="eager">
    {% else %}
      <div style="width:100%;height:100%;background:#F2F1EC;"></div>
    {% endif %}
  </div>
  <div class="yb-h-overlay-{{ uid }}"></div>
  <div class="wrapx">
    <div class="yb-h-inner-{{ uid }}">
      {% if s.eyebrow != blank %}<div class="yb-h-eyebrow-{{ uid }}">{{ s.eyebrow }}</div>{% endif %}
      {% if s.heading != blank %}<h1>{{ s.heading }}</h1>{% endif %}
      {% if s.body != blank %}<div class="yb-h-sub-{{ uid }}">{{ s.body }}</div>{% endif %}
      <div class="yb-h-cta-{{ uid }}">
        {% if s.button1_label != blank %}<a href="{{ s.button1_link | default: '#' }}" class="yb-btn-{{ uid }} yb-btn-fill-{{ uid }}">{{ s.button1_label }} <span>&rarr;</span></a>{% endif %}
        {% if s.button2_label != blank %}<a href="{{ s.button2_link | default: '#' }}" class="yb-btn-{{ uid }} yb-btn-line-{{ uid }}">{{ s.button2_label }}</a>{% endif %}
      </div>
      {% if s.stat1_num != blank or s.stat2_num != blank or s.stat3_num != blank %}
        <div class="yb-h-meta-{{ uid }}">
          {% if s.stat1_num != blank %}<div class="m"><b>{{ s.stat1_num }}</b><span>{{ s.stat1_label }}</span></div>{% endif %}
          {% if s.stat2_num != blank %}<div class="vr"></div><div class="m"><b>{{ s.stat2_num }}</b><span>{{ s.stat2_label }}</span></div>{% endif %}
          {% if s.stat3_num != blank %}<div class="vr"></div><div class="m"><b>{{ s.stat3_num }}</b><span>{{ s.stat3_label }}</span></div>{% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "YumBud · Hero",
  "tag": "section",
  "class": "yumbud-hero-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Human-grade · CDPH Licensed · Los Angeles" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "info": "Tip: italicise a word for the accent colour.", "default": "For the ones who <em>love us back.</em>" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Human-grade chicken, garden herbs and real produce — slow-dehydrated. Nothing artificial, nothing rendered. Just treats worth the wag.</p>" },
    { "type": "text", "id": "button1_label", "label": "Primary button label", "default": "Shop the Pantry" },
    { "type": "url", "id": "button1_link", "label": "Primary button link" },
    { "type": "text", "id": "button2_label", "label": "Secondary button label", "default": "Our Story" },
    { "type": "url", "id": "button2_link", "label": "Secondary button link" },
    { "type": "header", "content": "Content position" },
    { "type": "range", "id": "content_max_width", "label": "Content block width", "min": 200, "max": 900, "step": 10, "unit": "px", "default": 600 },
    { "type": "range", "id": "content_offset_left", "label": "Offset from left", "min": 0, "max": 800, "step": 1, "unit": "px", "default": 0 },
    { "type": "range", "id": "content_offset_right", "label": "Offset from right", "min": 0, "max": 800, "step": 1, "unit": "px", "default": 0 },
    { "type": "header", "content": "Background image" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (min 2000px wide recommended)" },
    { "type": "select", "id": "image_position", "label": "Image position", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "top center", "label": "Top" },
      { "value": "bottom center", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ], "default": "center center" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 20 },
    { "type": "header", "content": "Stats" },
    { "type": "text", "id": "stat1_num", "label": "Stat 1 number", "default": "4" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 label", "default": "Whole ingredients" },
    { "type": "text", "id": "stat2_num", "label": "Stat 2 number", "default": "0" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 label", "default": "Artificial additives" },
    { "type": "text", "id": "stat3_num", "label": "Stat 3 number", "default": "4.9" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 label", "default": "Average rating" },
    { "type": "header", "content": "Primary button" },
    { "type": "color", "id": "btn1_bg", "label": "Background color", "default": "#FFFFFF" },
    { "type": "color", "id": "btn1_text", "label": "Text color", "default": "#2B2420" },
    { "type": "color", "id": "btn1_border", "label": "Border color", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "btn1_transparent", "label": "Transparent background", "default": false },
    { "type": "header", "content": "Secondary button" },
    { "type": "color", "id": "btn2_bg", "label": "Background color", "default": "#FFFFFF" },
    { "type": "color", "id": "btn2_text", "label": "Text color", "default": "#2B2420" },
    { "type": "color", "id": "btn2_border", "label": "Border color", "default": "#FFFFFF" },
    { "type": "checkbox", "id": "btn2_transparent", "label": "Transparent background", "default": true },
    { "type": "header", "content": "Colours & Typography" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#574F46" },
    { "type": "color", "id": "accent_color", "label": "Accent (italic words)", "default": "#535B72" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Border frame" },
    { "type": "color", "id": "frame_color", "label": "Frame color", "default": "#FFFFFF" },
    { "type": "range", "id": "frame_width", "label": "Frame thickness", "min": 1, "max": 20, "step": 1, "unit": "px", "default": 2 },
    { "type": "text", "id": "frame_inset", "label": "Frame inset (px) — type any number", "default": "12" },
    { "type": "range", "id": "frame_opacity", "label": "Frame opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 80 },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "min_height", "label": "Min height", "min": 400, "max": 900, "step": 20, "unit": "px", "default": 620 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 88 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "presets": [ { "name": "YumBud · Hero" } ]
}
{% endschema %}
