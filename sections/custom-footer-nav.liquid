{% comment %}
  Custom Editable Footer Navigation Section
  Background: #F2F1EC
{% endcomment %}

<style>
  .custom-footer-nav {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 20px;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    border-top: 1px solid rgba(0,0,0,0.1);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 30px;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
  }

  .footer-heading {
    color: {{ section.settings.text_color }};
    font-size: 12px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 25px;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-link-item {
    margin-bottom: 12px;
  }

  .footer-link-item a {
    text-decoration: none;
    color: {{ section.settings.text_color }};
    font-size: 15px;
    opacity: 0.8;
    transition: opacity 0.3s ease;
  }

  .footer-link-item a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .contact-btn-wrapper {
    margin-top: 25px;
  }

  .contact-button {
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid {{ section.settings.text_color }};
    padding: 15px 20px;
    text-decoration: none;
    color: {{ section.settings.text_color }};
    font-size: 14px;
    transition: all 0.3s ease;
    width: 100%;
  }

  .contact-button:hover {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.bg_color }};
  }

  .contact-button svg {
    margin-left: 10px;
    width: 18px;
    height: 18px;
    fill: currentColor;
  }

  @media (max-width: 992px) {
    .footer-container {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .contact-button {
      justify-content: center;
    }
  }
</style>

<section class="custom-footer-nav">
  <div class="footer-container">
    {% for i in (1..4) %}
      {% capture menu_setting %}menu_{{ i }}{% endcapture %}
      {% assign current_menu = section.settings[menu_setting] %}
      {% capture title_setting %}title_{{ i }}{% endcapture %}
      {% assign current_title = section.settings[title_setting] %}

      <div class="footer-column">
        <div class="footer-heading">{{ current_title }}</div>
        <ul class="footer-links">
          {% for link in linklists[current_menu].links %}
            <li class="footer-link-item">
              <a href="{{ link.url }}">{{ link.title }}</a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}

    <div class="footer-column">
      <div class="footer-heading">{{ section.settings.contact_title }}</div>
      <div class="contact-btn-wrapper">
        <a href="{{ section.settings.contact_link }}" class="contact-button">
          {{ section.settings.contact_btn_text }}
          <svg viewBox="0 0 24 24"><path d="M13.025 1l-2.847 2.828 6.176 6.172h-16.348v4.048h16.348l-6.172 6.164 2.847 2.828L22 12z"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Footer Nav",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F2F1EC"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Border Color",
      "default": "#2D362E"
    },
    {
      "type": "header",
      "content": "Column 1"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Column 1 Title",
      "default": "SHOP"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 Menu"
    },
    {
      "type": "header",
      "content": "Column 2"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Column 2 Title",
      "default": "LEARN"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 Menu"
    },
    {
      "type": "header",
      "content": "Column 3"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Column 3 Title",
      "default": "HELP"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Column 3 Menu"
    },
    {
      "type": "header",
      "content": "Column 4"
    },
    {
      "type": "text",
      "id": "title_4",
      "label": "Column 4 Title",
      "default": "MORE"
    },
    {
      "type": "link_list",
      "id": "menu_4",
      "label": "Column 4 Menu"
    },
    {
      "type": "header",
      "content": "Contact Section"
    },
    {
      "type": "text",
      "id": "contact_title",
      "label": "Contact Title",
      "default": "CONTACT"
    },
    {
      "type": "text",
      "id": "contact_btn_text",
      "label": "Button Text",
      "default": "Go to the Help Center"
    },
    {
      "type": "url",
      "id": "contact_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Footer Nav"
    }
  ]
}
{% endschema %}
