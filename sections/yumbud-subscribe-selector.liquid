{%- comment -%}
  YumBud · Subscribe Selector + Price Compare (integrated)
  Price compare card updates dynamically when frequency changes.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-muted:{{ s.muted_color }};
    --yb-accent:{{ s.accent_color }}; --yb-card:{{ s.card_color }};
    --yb-line:{{ s.text_color }}1f;
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  .yb-ss-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  .yb-ss-wrap-{{ uid }}{ max-width:1180px; margin:0 auto; padding:0 40px; }
  .yb-ss-grid-{{ uid }}{ display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:start; }
  .yb-ss-img-{{ uid }}{ background:var(--yb-card); border-radius:8px; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; overflow:hidden; position:sticky; top:120px; }
  .yb-ss-img-{{ uid }} img{ width:100%; height:100%; object-fit:cover; }
  .yb-ss-eyebrow-{{ uid }}{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-muted); margin-bottom:14px; }
  .yb-ss-{{ uid }} h2{ font-family:var(--yb-serif); font-size:clamp(28px,3.6vw,42px); font-weight:500; line-height:1.1; margin-bottom:18px; }
  .yb-ss-sub-{{ uid }}{ font-size:15px; color:var(--yb-muted); margin-bottom:30px; line-height:1.6; }
  .yb-ss-label-{{ uid }}{ font-size:11px; letter-spacing:.16em; text-transform:uppercase; font-weight:500; margin-bottom:12px; color:var(--yb-ink); display:flex; justify-content:space-between; align-items:center; }
  .yb-ss-label-{{ uid }} .hint{ font-size:11px; letter-spacing:.06em; text-transform:none; color:var(--yb-muted); font-weight:400; }

  /* Flavors */
  .yb-ss-flavors-{{ uid }}{ display:flex; flex-direction:column; gap:8px; margin-bottom:26px; }
  .yb-ss-fl-{{ uid }}{ display:flex; align-items:center; gap:14px; padding:14px 18px; border:1px solid var(--yb-line); border-radius:10px; background:var(--yb-bg); cursor:pointer; transition:.2s; }
  .yb-ss-fl-{{ uid }}.active{ border-color:var(--yb-ink); border-width:2px; padding:13px 17px; background:var(--yb-card); }
  .yb-ss-fl-{{ uid }} .th{ width:50px; height:50px; border-radius:6px; background:var(--yb-card); overflow:hidden; flex:none; display:flex; align-items:center; justify-content:center; }
  .yb-ss-fl-{{ uid }} .th img{ width:100%; height:100%; object-fit:cover; }
  .yb-ss-fl-{{ uid }} .info{ flex:1; }
  .yb-ss-fl-{{ uid }} .nm{ font-size:15px; font-weight:500; margin-bottom:2px; }
  .yb-ss-fl-{{ uid }} .dsc{ font-size:12px; color:var(--yb-muted); }
  .yb-ss-fl-{{ uid }} .qty{ display:flex; align-items:center; gap:8px; }
  .yb-ss-fl-{{ uid }} .qty button{ width:28px; height:28px; border:1px solid var(--yb-line); background:var(--yb-bg); border-radius:50%; cursor:pointer; font-size:14px; color:var(--yb-ink); }
  .yb-ss-fl-{{ uid }} .qty button:disabled{ opacity:.35; cursor:not-allowed; }
  .yb-ss-fl-{{ uid }} .qty .n{ min-width:20px; text-align:center; font-size:14px; font-weight:500; }

  /* Frequency */
  .yb-ss-freq-{{ uid }}{ display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:28px; }
  .yb-ss-fbox-{{ uid }}{ border:1px solid var(--yb-line); border-radius:6px; padding:16px 14px; cursor:pointer; text-align:center; transition:.2s; background:var(--yb-bg); }
  .yb-ss-fbox-{{ uid }}.active{ border-color:var(--yb-ink); border-width:2px; padding:15px 13px; }
  .yb-ss-fbox-{{ uid }} .ttl{ font-size:14px; font-weight:500; margin-bottom:3px; }
  .yb-ss-fbox-{{ uid }} .sub{ font-size:11px; color:var(--yb-muted); }
  .yb-ss-fbox-{{ uid }} .save{ display:inline-block; margin-top:6px; font-size:10px; background:var(--yb-accent); color:#fff; padding:2px 8px; border-radius:12px; letter-spacing:.04em; }

  /* Price Compare */
  .yb-ss-compare-{{ uid }}{ display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:28px; }
  .yb-ss-ccard-{{ uid }}{ border-radius:10px; padding:22px 20px; position:relative; background:var(--yb-card); }
  .yb-ss-ccard-{{ uid }}.featured{ background:var(--yb-ink); color:var(--yb-bg); }
  .yb-ss-ccard-{{ uid }} .ctag{ position:absolute; top:14px; right:14px; background:var(--yb-accent); color:#fff; padding:3px 10px; border-radius:20px; font-size:9px; letter-spacing:.12em; text-transform:uppercase; }
  .yb-ss-ccard-{{ uid }} .cnm{ font-size:10px; letter-spacing:.14em; text-transform:uppercase; margin-bottom:12px; opacity:.65; }
  .yb-ss-ccard-{{ uid }} .cpr{ font-family:var(--yb-serif); font-size:34px; font-weight:500; line-height:1; margin-bottom:4px; }
  .yb-ss-ccard-{{ uid }} .cper{ font-size:12px; opacity:.55; }
  .yb-ss-ccard-{{ uid }} .cdesc{ font-size:12px; opacity:.7; margin-top:8px; line-height:1.4; }
  .yb-ss-cfeats-{{ uid }}{ list-style:none; padding:0; margin:14px 0 0; }
  .yb-ss-cfeats-{{ uid }} li{ padding:7px 0; font-size:12px; border-bottom:1px solid currentColor; opacity:.8; display:flex; align-items:center; gap:8px; }
  .yb-ss-cfeats-{{ uid }} li:last-child{ border-bottom:none; }

  /* Summary */
  .yb-ss-summary-{{ uid }}{ padding:18px 0 22px; border-top:1px solid var(--yb-line); border-bottom:1px solid var(--yb-line); margin-bottom:22px; }
  .yb-ss-row-{{ uid }}{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; font-size:14px; }
  .yb-ss-row-{{ uid }} .lbl{ color:var(--yb-muted); }
  .yb-ss-row-{{ uid }}.total{ margin-top:14px; padding-top:14px; border-top:1px dashed var(--yb-line); margin-bottom:0; }
  .yb-ss-row-{{ uid }}.total .lbl{ font-size:14px; color:var(--yb-ink); font-weight:500; text-transform:uppercase; letter-spacing:.12em; }
  .yb-ss-row-{{ uid }}.total .val{ font-family:var(--yb-serif); font-size:30px; font-weight:500; }

  .yb-ss-btn-{{ uid }}{ display:block; width:100%; background:var(--yb-ink); color:var(--yb-bg); padding:16px; border:none; border-radius:30px; font-size:13px; letter-spacing:.16em; text-transform:uppercase; font-weight:500; cursor:pointer; text-align:center; text-decoration:none; }
  .yb-ss-btn-{{ uid }}:hover{ opacity:.86; }
  .yb-ss-note-{{ uid }}{ text-align:center; font-size:12px; color:var(--yb-muted); margin-top:12px; }

  @media (max-width:880px){
    .yb-ss-grid-{{ uid }}{ grid-template-columns:1fr; gap:32px; }
    .yb-ss-img-{{ uid }}{ position:static; }
    .yb-ss-wrap-{{ uid }}{ padding:0 24px; }
  }
</style>

<section class="yb-ss-{{ uid }}">
  <div class="yb-ss-wrap-{{ uid }}">
    <div class="yb-ss-grid-{{ uid }}">
      <div class="yb-ss-img-{{ uid }}">
        {% if s.product_image != blank %}
          <img src="{{ s.product_image | image_url: width: 800 }}" alt="">
        {% else %}
          <span style="font-size:80px;">📦</span>
        {% endif %}
      </div>
      <div>
        {% if s.eyebrow != blank %}<div class="yb-ss-eyebrow-{{ uid }}">{{ s.eyebrow }}</div>{% endif %}
        {% if s.heading != blank %}<h2>{{ s.heading }}</h2>{% endif %}
        {% if s.body != blank %}<div class="yb-ss-sub-{{ uid }}">{{ s.body }}</div>{% endif %}

        {% if section.blocks.size > 0 %}
          <div class="yb-ss-label-{{ uid }}">
            <span>{{ s.flavor_label }}</span>
            <span class="hint">{{ s.flavor_hint }}</span>
          </div>
          <div class="yb-ss-flavors-{{ uid }}" data-yb-flavors>
            {% for block in section.blocks %}
              {% if block.type == 'flavor' %}
                {%- assign product = all_products[block.settings.product] -%}
                {%- if product != blank and product != empty -%}
                  {%- assign display_name = block.settings.name_override | default: product.title -%}
                  {%- assign display_desc = block.settings.desc_override | default: product.metafields.custom.short_desc -%}
                  {%- assign display_price = product.price | money_without_trailing_zeros -%}
                  {%- assign price_value = product.price | divided_by: 100.0 -%}
                  {%- assign display_image = block.settings.image_override | default: product.featured_image -%}
                  {%- assign variant_id = product.selected_or_first_available_variant.id -%}
                  <div class="yb-ss-fl-{{ uid }}" data-yb-flavor data-price="{{ price_value }}" data-variant-id="{{ variant_id }}" {{ block.shopify_attributes }}>
                    <div class="th">
                      {% if display_image != blank %}<img src="{{ display_image | image_url: width: 120 }}" alt="">{% else %}<span style="font-size:22px;">🍖</span>{% endif %}
                    </div>
                    <div class="info">
                      <div class="nm">{{ display_name }}</div>
                      <div class="dsc">{% if display_desc != blank %}{{ display_desc }} · {% endif %}{{ display_price }}/bag</div>
                    </div>
                    <div class="qty">
                      <button type="button" data-yb-dec aria-label="Decrease">−</button>
                      <span class="n" data-yb-n>0</span>
                      <button type="button" data-yb-inc aria-label="Increase">+</button>
                    </div>
                  </div>
                {%- else -%}
                  <div class="yb-ss-fl-{{ uid }}" {{ block.shopify_attributes }} style="opacity:.5;">
                    <div class="info"><div class="nm">⚠ Select a product in block settings</div></div>
                  </div>
                {%- endif -%}
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        <div class="yb-ss-label-{{ uid }}"><span>{{ s.freq_label }}</span></div>
        <div class="yb-ss-freq-{{ uid }}" data-yb-freqs>
          <div class="yb-ss-fbox-{{ uid }} active" data-yb-freq data-discount="15" data-selling-plan="8934654243">
            <div class="ttl">Every 2 weeks</div>
            <div class="sub">Most popular</div>
            <div class="save">Save 15%</div>
          </div>
          <div class="yb-ss-fbox-{{ uid }}" data-yb-freq data-discount="10" data-selling-plan="8934392099">
            <div class="ttl">Monthly</div>
            <div class="sub">Most flexible</div>
            <div class="save">Save 10%</div>
          </div>
          <div class="yb-ss-fbox-{{ uid }}" data-yb-freq data-discount="8" data-selling-plan="8934621475">
            <div class="ttl">Every 2 months</div>
            <div class="sub">Best value</div>
            <div class="save">Save 8%</div>
          </div>
        </div>

        <!-- Price Compare (dynamic) -->
        {% if s.show_compare %}
        <div class="yb-ss-label-{{ uid }}"><span>{{ s.compare_label | default: 'Why subscribe?' }}</span></div>
        <div class="yb-ss-compare-{{ uid }}">
          <div class="yb-ss-ccard-{{ uid }}">
            <div class="cnm">{{ s.left_title | default: 'One-time' }}</div>
            <div class="cpr">${{ s.base_price | default: '17.99' }}</div>
            <div class="cper">/ bag</div>
            <div class="cdesc">{{ s.left_desc | default: 'Buy once, no commitment.' }}</div>
            <ul class="yb-ss-cfeats-{{ uid }}">
              {% for block in section.blocks %}{% if block.type == 'left_feature' %}
                <li><span>○</span>{{ block.settings.text }}</li>
              {% endif %}{% endfor %}
            </ul>
          </div>
          <div class="yb-ss-ccard-{{ uid }} featured">
            <span class="ctag" data-yb-ctag>Save 15%</span>
            <div class="cnm">{{ s.right_title | default: 'Subscribe & Save' }}</div>
            <div class="cpr" data-yb-sub-price>$15.29</div>
            <div class="cper">/ bag</div>
            <div class="cdesc" data-yb-sub-desc>Save 15% on every delivery. Cancel anytime.</div>
            <ul class="yb-ss-cfeats-{{ uid }}">
              {% for block in section.blocks %}{% if block.type == 'right_feature' %}
                <li><span>✓</span>{{ block.settings.text }}</li>
              {% endif %}{% endfor %}
            </ul>
          </div>
        </div>
        {% endif %}

        <div class="yb-ss-summary-{{ uid }}">
          <div class="yb-ss-row-{{ uid }}">
            <span class="lbl">{{ s.subtotal_label }}</span>
            <span class="val">$<span data-yb-subtotal>0</span></span>
          </div>
          <div class="yb-ss-row-{{ uid }}">
            <span class="lbl">{{ s.discount_label }} (<span data-yb-disc-pct>15</span>%)</span>
            <span class="val">−$<span data-yb-discount>0</span></span>
          </div>
          <div class="yb-ss-row-{{ uid }} total">
            <span class="lbl">{{ s.total_label }}</span>
            <span class="val">$<span data-yb-total>0</span></span>
          </div>
        </div>

        <button type="button" class="yb-ss-btn-{{ uid }}" data-yb-cta>{{ s.button_label }}</button>
        {% if s.note != blank %}<div class="yb-ss-note-{{ uid }}">{{ s.note }}</div>{% endif %}
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var root=document.getElementById('shopify-section-{{ uid }}');
  if(!root) return;
  var rows=root.querySelectorAll('[data-yb-flavor]');
  var freqs=root.querySelectorAll('[data-yb-freq]');
  var subEl=root.querySelector('[data-yb-subtotal]');
  var discEl=root.querySelector('[data-yb-discount]');
  var totEl=root.querySelector('[data-yb-total]');
  var pctEl=root.querySelector('[data-yb-disc-pct]');
  var btn=root.querySelector('[data-yb-cta]');
  var subPriceEl=root.querySelector('[data-yb-sub-price]');
  var subDescEl=root.querySelector('[data-yb-sub-desc]');
  var ctagEl=root.querySelector('[data-yb-ctag]');

  var BASE_PRICE = {{ s.base_price | default: 17.99 }};

  var freqData = {
    '8934654243': { discount: 15, label: 'Every 2 weeks' },
    '8934392099': { discount: 10, label: 'Monthly' },
    '8934621475': { discount: 8,  label: 'Every 2 months' }
  };

  function getActive(){ return root.querySelector('[data-yb-freq].active'); }
  function getDiscount(){ var a=getActive(); return a?parseFloat(a.getAttribute('data-discount')||'0'):0; }
  function getSellingPlan(){ var a=getActive(); return a?a.getAttribute('data-selling-plan'):null; }

  function updateCompare(){
    var pct = getDiscount();
    var subPrice = BASE_PRICE * (1 - pct/100);
    if(subPriceEl) subPriceEl.textContent = '$' + subPrice.toFixed(2);
    if(ctagEl) ctagEl.textContent = 'Save ' + pct + '%';
    var planId = getSellingPlan();
    var label = planId && freqData[planId] ? freqData[planId].label : '';
    if(subDescEl) subDescEl.textContent = 'Save ' + pct + '% — delivered ' + label.toLowerCase() + '. Cancel anytime.';
  }

  function recalc(){
    var subtotal=0;
    rows.forEach(function(r){
      var nEl=r.querySelector('[data-yb-n]'); if(!nEl) return;
      var n=parseInt(nEl.textContent)||0;
      var p=parseFloat(r.getAttribute('data-price'))||0;
      subtotal+=n*p;
      r.classList.toggle('active', n>0);
    });
    var pct=getDiscount();
    var discount=Math.round(subtotal*pct)/100;
    discount=Math.round(discount*100)/100;
    var total=Math.round((subtotal-discount)*100)/100;
    if(subEl) subEl.textContent=subtotal.toFixed(2);
    if(discEl) discEl.textContent=discount.toFixed(2);
    if(totEl) totEl.textContent=total.toFixed(2);
    if(pctEl) pctEl.textContent=Math.round(pct);
    if(btn){ btn.style.opacity=subtotal>0?'1':'.4'; btn.style.pointerEvents=subtotal>0?'auto':'none'; }
    updateCompare();
  }

  rows.forEach(function(r){
    var nEl=r.querySelector('[data-yb-n]'); if(!nEl) return;
    var dec=r.querySelector('[data-yb-dec]');
    var inc=r.querySelector('[data-yb-inc]');
    if(dec) dec.onclick=function(){ var n=parseInt(nEl.textContent)||0; if(n>0){ nEl.textContent=n-1; recalc(); } };
    if(inc) inc.onclick=function(){ var n=parseInt(nEl.textContent)||0; nEl.textContent=n+1; recalc(); };
  });

  freqs.forEach(function(b){
    b.onclick=function(){
      freqs.forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      recalc();
    };
  });

  if(btn){
    btn.onclick=function(){
      var items=[];
      var sellingPlanId=getSellingPlan();
      rows.forEach(function(r){
        var nEl=r.querySelector('[data-yb-n]'); if(!nEl) return;
        var n=parseInt(nEl.textContent)||0;
        var id=r.getAttribute('data-variant-id');
        if(n>0 && id){
          var item={ id:parseInt(id), quantity:n };
          if(sellingPlanId) item.selling_plan=parseInt(sellingPlanId);
          items.push(item);
        }
      });
      if(items.length===0) return;
      btn.textContent='Adding...';
      btn.style.opacity='.6';
      fetch('/cart/add.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({items:items})
      })
      .then(function(r){ return r.json(); })
      .then(function(){ window.location.href='/cart'; })
      .catch(function(){
        btn.textContent={{ s.button_label | json }};
        btn.style.opacity='1';
      });
    };
  }

  recalc();
})();
</script>

{% schema %}
{
  "name": "YumBud · Subscribe",
  "tag": "section",
  "class": "yumbud-subscribe-selector",
  "max_blocks": 16,
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Subscribe & Save" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Build your box." },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Pick any combination of flavors. Add as many bags as you want.</p>" },
    { "type": "image_picker", "id": "product_image", "label": "Main image" },
    { "type": "header", "content": "Flavor selector" },
    { "type": "text", "id": "flavor_label", "label": "Label", "default": "Choose your flavors" },
    { "type": "text", "id": "flavor_hint", "label": "Hint", "default": "Mix and match" },
    { "type": "header", "content": "Frequency selector" },
    { "type": "text", "id": "freq_label", "label": "Label", "default": "Delivery frequency" },
    { "type": "header", "content": "Price Compare" },
    { "type": "checkbox", "id": "show_compare", "label": "Show price compare", "default": true },
    { "type": "text", "id": "compare_label", "label": "Compare section label", "default": "Why subscribe?" },
    { "type": "text", "id": "base_price", "label": "Base price per bag (one-time)", "default": "17.99", "info": "Used to calculate subscribe price dynamically" },
    { "type": "text", "id": "left_title", "label": "Left card title", "default": "One-time" },
    { "type": "text", "id": "left_desc", "label": "Left card description", "default": "Buy once, no commitment." },
    { "type": "text", "id": "right_title", "label": "Right card title", "default": "Subscribe & Save" },
    { "type": "header", "content": "Summary labels" },
    { "type": "text", "id": "subtotal_label", "label": "Subtotal label", "default": "Subtotal" },
    { "type": "text", "id": "discount_label", "label": "Discount label", "default": "Subscriber discount" },
    { "type": "text", "id": "total_label", "label": "Total label", "default": "Total" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Start Subscription" },
    { "type": "text", "id": "note", "label": "Note below button", "default": "Free shipping · Skip or cancel anytime" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#8C8578" },
    { "type": "color", "id": "accent_color", "label": "Save badge", "default": "#2E3D2A" },
    { "type": "color", "id": "card_color", "label": "Image/active background", "default": "#E8E4DA" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    { "type": "flavor", "name": "Flavor (product)", "settings": [
      { "type": "product", "id": "product", "label": "Product" },
      { "type": "text", "id": "name_override", "label": "Display name (optional)", "info": "Leave empty to use product title" },
      { "type": "text", "id": "desc_override", "label": "Description (optional)", "info": "Leave empty to use product metafield" },
      { "type": "image_picker", "id": "image_override", "label": "Thumbnail (optional)" }
    ] },
    { "type": "left_feature", "name": "One-time feature", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Full price" }
    ] },
    { "type": "right_feature", "name": "Subscribe feature", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Discount on every order" }
    ] }
  ],
  "presets": [
    { "name": "YumBud · Subscribe", "blocks": [
      { "type": "flavor" },
      { "type": "flavor" },
      { "type": "flavor" },
      { "type": "flavor" },
      { "type": "left_feature", "settings": { "text": "Full price $17.99/bag" } },
      { "type": "left_feature", "settings": { "text": "Standard shipping" } },
