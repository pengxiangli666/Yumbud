{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --bg:{{ s.bg_color }}; --ink:{{ s.text_color }}; --muted:{{ s.muted_color }};
    --accent:{{ s.accent_color }}; --card:{{ s.card_color }}; --line:{{ s.text_color }}20;
    --serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  #shopify-section-{{ uid }} .ct{ background:var(--bg); color:var(--ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  #shopify-section-{{ uid }} *{ box-sizing:border-box; }
  #shopify-section-{{ uid }} .ct-in{ max-width:1100px; margin:0 auto; padding:0 clamp(20px,5vw,56px); display:grid; grid-template-columns:1fr 1fr; gap:clamp(40px,6vw,88px); align-items:start; }
  #shopify-section-{{ uid }} .ct-left .eyebrow{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--muted); margin-bottom:14px; }
  #shopify-section-{{ uid }} .ct-left h1{ font-family:var(--serif); font-weight:500; font-size:clamp(28px,4vw,52px); line-height:1.08; margin:0 0 20px; }
  #shopify-section-{{ uid }} .ct-left .sub{ font-size:15px; line-height:1.75; color:var(--muted); max-width:42ch; }
  #shopify-section-{{ uid }} .ct-left .sub p{ margin:0 0 .8em; }
  #shopify-section-{{ uid }} .ct-left .sub p:last-child{ margin:0; }

  /* form */
  #shopify-section-{{ uid }} .ct-form{ display:flex; flex-direction:column; gap:12px; }
  #shopify-section-{{ uid }} .ct-row{ display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  #shopify-section-{{ uid }} .ct-form input,
  #shopify-section-{{ uid }} .ct-form textarea{
    width:100%; padding:13px 16px; border:1px solid var(--line);
    background:#fff; font-size:14px; color:var(--ink);
    border-radius:2px; outline:none; font-family:inherit;
    transition:border-color .2s;
  }
  #shopify-section-{{ uid }} .ct-form input:focus,
  #shopify-section-{{ uid }} .ct-form textarea:focus{ border-color:var(--accent); }
  #shopify-section-{{ uid }} .ct-form input::placeholder,
  #shopify-section-{{ uid }} .ct-form textarea::placeholder{ color:#A09080; }
  #shopify-section-{{ uid }} .ct-form textarea{ min-height:140px; resize:vertical; }
  #shopify-section-{{ uid }} .ct-btn{
    display:inline-flex; align-items:center; justify-content:center;
    padding:14px 32px; background:var(--ink); color:var(--bg);
    border:none; font-size:13px; letter-spacing:.08em;
    cursor:pointer; border-radius:2px; font-family:inherit;
    transition:background .2s; align-self:flex-start;
  }
  #shopify-section-{{ uid }} .ct-btn:hover{ background:var(--accent); }
  #shopify-section-{{ uid }} .ct-success{ display:none; padding:16px; background:var(--card); border-radius:2px; font-size:14px; color:var(--ink); }

  @media(max-width:760px){
    #shopify-section-{{ uid }} .ct-in{ grid-template-columns:1fr; gap:32px; }
    #shopify-section-{{ uid }} .ct-row{ grid-template-columns:1fr; }
  }
</style>

<div class="ct">
  <div class="ct-in">

    <!-- Left: heading + intro -->
    <div class="ct-left">
      {% if s.eyebrow != blank %}<div class="eyebrow">{{ s.eyebrow }}</div>{% endif %}
      <h1>{{ s.heading | default: 'Contact Yumbud' }}</h1>
      {% if s.subheading != blank %}
        <div class="sub">{{ s.subheading }}</div>
      {% endif %}
    </div>

    <!-- Right: form -->
    <div class="ct-right">
      {%- form 'contact', id: 'ContactForm' -%}
        <div class="ct-form">
          <div class="ct-row">
            <input type="text" name="contact[name]" placeholder="{{ s.label_name | default: 'Name' }}" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}">
            <input type="email" name="contact[email]" required placeholder="{{ s.label_email | default: 'Email *' }}" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}">
          </div>
          <input type="tel" name="contact[phone]" placeholder="{{ s.label_phone | default: 'Phone number' }}" value="{{ form.phone }}">
          <textarea name="contact[body]" placeholder="{{ s.label_message | default: 'Comment' }}">{{ form.body }}</textarea>
          <button type="submit" class="ct-btn">{{ s.btn_label | default: 'Send' }}</button>
          {% if form.posted_successfully? %}
            <div class="ct-success" style="display:block;">{{ s.success_msg | default: "Thanks for reaching out — we'll be in touch soon!" }}</div>
          {% endif %}
          {% if form.errors %}
            <div class="ct-success" style="display:block; background:#fdecea;">{{ form.errors | default_errors }}</div>
          {% endif %}
        </div>
      {%- endform -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "YumBud · Contact",
  "tag": "section",
  "class": "yumbud-contact-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Get in touch" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Contact Yumbud" },
    { "type": "richtext", "id": "subheading", "label": "Subheading", "default": "<p>We're here to help you and your pup. Have a question about your order, our treats, ingredients, subscriptions, or anything else? Send us a message — the Yumbud team will get back to you as soon as possible.</p>" },
    { "type": "header", "content": "Form labels" },
    { "type": "text", "id": "label_name", "label": "Name placeholder", "default": "Name" },
    { "type": "text", "id": "label_email", "label": "Email placeholder", "default": "Email *" },
    { "type": "text", "id": "label_phone", "label": "Phone placeholder", "default": "Phone number" },
    { "type": "text", "id": "label_message", "label": "Message placeholder", "default": "Comment" },
    { "type": "text", "id": "btn_label", "label": "Button label", "default": "Send" },
    { "type": "text", "id": "success_msg", "label": "Success message", "default": "Thanks for reaching out — we'll be in touch soon!" },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#574F46" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#A0714F" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#ECEAE3" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [
    { "name": "YumBud · Contact" }
  ]
}
{% endschema %}
