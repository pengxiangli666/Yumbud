{%- comment -%}
  ============================================================
  YumBud · Value Marquee (Online Store 2.0)
  Auto-scrolling strip of short value phrases. Each phrase is a
  block — add / remove / reorder in the Customizer. Pauses on hover.
  ============================================================
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-sand:{{ s.accent_color }};
    --yb-line:{{ s.text_color }}22;
  }
  .yb-mq-{{ uid }}{ background:var(--yb-bg); overflow:hidden; padding:16px 0;
    border-top:1px solid var(--yb-line); border-bottom:1px solid var(--yb-line); }
  .yb-mq-track-{{ uid }}{ display:flex; width:max-content; animation:yb-mq-{{ uid }} {{ s.speed }}s linear infinite; }
  .yb-mq-{{ uid }}:hover .yb-mq-track-{{ uid }}{ animation-play-state:paused; }
  .yb-mq-track-{{ uid }} span{ font-size:12px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-ink);
    font-weight:500; padding:0 26px; display:flex; align-items:center; gap:26px; white-space:nowrap; opacity:.82; }
  .yb-mq-track-{{ uid }} span::before{ content:"\2726"; color:var(--yb-sand); font-size:9px; }
  @keyframes yb-mq-{{ uid }}{ to{ transform:translateX(-50%); } }
  @media (prefers-reduced-motion:reduce){ .yb-mq-track-{{ uid }}{ animation:none; flex-wrap:wrap; justify-content:center; } }
</style>

<div class="yb-mq-{{ uid }}">
  <div class="yb-mq-track-{{ uid }}">
    {%- comment -%} render the blocks twice for a seamless loop {%- endcomment -%}
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <span {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "YumBud · Marquee",
  "tag": "section",
  "class": "yumbud-marquee-section",
  "max_blocks": 12,
  "settings": [
    { "type": "range", "id": "speed", "label": "Scroll duration (lower = faster)", "min": 12, "max": 60, "step": 2, "unit": "s", "default": 34 },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ECEAE3" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#574F46" },
    { "type": "color", "id": "accent_color", "label": "Separator star", "default": "#B8A88B" }
  ],
  "blocks": [
    { "type": "phrase", "name": "Phrase", "settings": [
      { "type": "text", "id": "text", "label": "Phrase", "default": "Human-grade" }
    ] }
  ],
  "presets": [
    { "name": "YumBud · Marquee", "blocks": [
      { "type": "phrase", "settings": { "text": "Human-grade" } },
      { "type": "phrase", "settings": { "text": "No artificial additives" } },
      { "type": "phrase", "settings": { "text": "Gently dehydrated" } },
      { "type": "phrase", "settings": { "text": "Single-origin protein" } },
      { "type": "phrase", "settings": { "text": "Made in California" } },
      { "type": "phrase", "settings": { "text": "Vet-considered" } }
    ] }
  ]
}
{% endschema %}
