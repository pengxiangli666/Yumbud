{%- comment -%}
  ============================================================
  YumBud · Header  (Maev-style, custom header for Dawn / OS2.0)
  Layout:  [ ☰ Shop & Learn ] ........ maev ........ [ Help | account | cart ]
  - Hairline divider "grid" between cells (toggle).
  - Dark announcement bar on top.
  - Transparent over a full-bleed hero on the homepage, turns
    solid on scroll. Fixed overlay (works without theme support).
  - The ☰ "Shop & Learn" opens a left slide-in menu drawer
    (uses your real Shopify menu, with sub-items).
  - Separate light/dark logos so the wordmark stays legible white
    over the hero and dark once the bar goes solid.

  INSTALL ON DAWN (simplest): Edit code > open sections/header.liquid
  > back up its contents elsewhere > replace ALL of it with this
  file > Save. Then Customize > Header to set menu, logos, colours.
  (Hide your theme's separate announcement bar — this has its own.)
  ============================================================
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
{%- assign menu = s.menu -%}
{%- assign logo_light = s.logo_light | default: s.logo_dark -%}
{%- assign logo_dark = s.logo_dark | default: s.logo_light -%}
{%- assign overlay = false -%}
{%- if s.transparent_home and request.page_type == 'index' -%}{%- assign overlay = true -%}{%- endif -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-tcolor:{{ s.transparent_text_color }};
    --yb-accent:{{ s.accent_color }}; --yb-ann-bg:{{ s.ann_bg }}; --yb-ann-fg:{{ s.ann_text }};
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
    --yb-ease:cubic-bezier(.22,.61,.36,1);
    --yb-line-solid:{{ s.text_color }}24; --yb-line-trans:{{ s.transparent_text_color }}3d;
  }
  .yb-top-{{ uid }}{ position:fixed; top:0; left:0; right:0; z-index:50; }
  .yb-ann-{{ uid }}{ background:var(--yb-ann-bg); color:var(--yb-ann-fg); text-align:center;
    font-size:11px; letter-spacing:.08em; padding:11px 16px; }
  .yb-ann-{{ uid }} a{ color:inherit; text-decoration:none; display:inline-flex; align-items:center; gap:8px; }
  .yb-ann-{{ uid }} a:hover{ text-decoration:underline; text-underline-offset:3px; }
  /* header bar */
  .yb-hdr-{{ uid }}{ color:var(--yb-tcolor); background:transparent;
    transition:background .45s var(--yb-ease),color .45s var(--yb-ease); }
  .yb-bar-{{ uid }}{ display:grid; grid-template-columns:1fr auto 1fr; align-items:stretch; height:64px; }
  .yb-divided-{{ uid }} .yb-bar-{{ uid }}{ border-top:1px solid var(--yb-line-trans); border-bottom:1px solid var(--yb-line-trans); transition:border-color .45s var(--yb-ease); }
  .yb-left-{{ uid }}{ display:flex; align-items:center; gap:13px; padding:0 28px; background:none; border:none;
    color:inherit; cursor:pointer; font-family:inherit; font-size:13px; letter-spacing:.04em; justify-self:start; }
  .yb-divided-{{ uid }} .yb-left-{{ uid }}{ border-right:1px solid var(--yb-line-trans); transition:border-color .45s var(--yb-ease); }
  .yb-left-{{ uid }} svg{ width:20px; height:14px; stroke:currentColor; stroke-width:1.5; }
  .yb-brand-{{ uid }}{ justify-self:center; align-self:center; display:flex; align-items:center; color:inherit; }
  .yb-brand-{{ uid }} img{ height:{{ s.logo_height }}px; width:auto; display:block; }
  .yb-brand-txt-{{ uid }}{ font-family:var(--yb-serif); font-style:italic; font-size:30px; font-weight:500; letter-spacing:.01em; color:inherit; }
  .yb-logo-dark-{{ uid }}{ display:none; }
  .yb-right-{{ uid }}{ justify-self:end; display:flex; align-items:stretch; }
  .yb-cell-{{ uid }}{ display:flex; align-items:center; gap:9px; padding:0 24px; color:inherit; position:relative; transition:opacity .3s; font-size:13px; letter-spacing:.04em; }
  .yb-cell-{{ uid }}:hover{ opacity:.62; }
  .yb-divided-{{ uid }} .yb-right-{{ uid }} .yb-cell-{{ uid }}{ border-left:1px solid var(--yb-line-trans); transition:border-color .45s var(--yb-ease); }
  .yb-ic-{{ uid }}{ width:19px; height:19px; stroke:currentColor; stroke-width:1.4; fill:none; }
  .yb-count-{{ uid }}{ position:absolute; top:12px; right:14px; background:var(--yb-accent); color:#fff; font-size:9px; font-weight:600;
    min-width:15px; height:15px; padding:0 3px; border-radius:9px; display:flex; align-items:center; justify-content:center; }
  /* SOLID state */
  .yb-top-{{ uid }}.yb-solid .yb-hdr-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); }
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-bar-{{ uid }},
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-left-{{ uid }},
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-right-{{ uid }} .yb-cell-{{ uid }}{ border-color:var(--yb-line-solid); }
  .yb-top-{{ uid }}.yb-solid .yb-logo-light-{{ uid }}{ display:none; }
  .yb-top-{{ uid }}.yb-solid .yb-logo-dark-{{ uid }}{ display:block; }
  /* drawer */
  .yb-scrim-{{ uid }}{ position:fixed; inset:0; background:rgba(33,29,24,.42); backdrop-filter:blur(3px); z-index:80; opacity:0; pointer-events:none; transition:.4s; }
  .yb-scrim-{{ uid }}.open{ opacity:1; pointer-events:auto; }
  .yb-drawer-{{ uid }}{ position:fixed; top:0; left:0; height:100%; width:380px; max-width:88vw; background:var(--yb-bg); color:var(--yb-ink);
    z-index:81; transform:translateX(-100%); transition:.5s var(--yb-ease); padding:30px 34px; overflow-y:auto; box-shadow:30px 0 80px -40px rgba(0,0,0,.4); }
  .yb-drawer-{{ uid }}.open{ transform:none; }
  .yb-dhead-{{ uid }}{ display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; }
  .yb-dhead-{{ uid }} span{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-ink); opacity:.6; }
  .yb-dx-{{ uid }}{ background:none; border:none; color:inherit; cursor:pointer; }
  .yb-drawer-{{ uid }} a{ display:block; font-family:var(--yb-serif); font-size:30px; font-weight:500; color:var(--yb-ink); padding:12px 0; border-bottom:1px solid var(--yb-line-solid); }
  .yb-drawer-{{ uid }} a.sub{ font-family:inherit; font-size:15px; padding:9px 0 9px 16px; opacity:.78; border-bottom:1px solid {{ s.text_color }}0d; }
  @media (max-width:760px){
    .yb-bar-{{ uid }}{ grid-template-columns:auto 1fr auto; height:56px; }
    .yb-left-{{ uid }}{ padding:0 18px; }
    .yb-left-label-{{ uid }}{ display:none; }
    .yb-cell-{{ uid }}{ padding:0 14px; }
    .yb-cell-hidem-{{ uid }}{ display:none; }
    .yb-count-{{ uid }}{ right:6px; }
  }
</style>

<div class="yb-top-{{ uid }} {% if s.show_dividers %}yb-divided-{{ uid }}{% endif %} {% unless overlay %}yb-solid{% endunless %}"
     data-yb-top data-overlay="{% if overlay %}1{% else %}0{% endif %}">
  {% if s.show_announcement and s.announcement_text != blank %}
    <div class="yb-ann-{{ uid }}">
      {% if s.announcement_link != blank %}<a href="{{ s.announcement_link }}">{{ s.announcement_text }} <span>&rarr;</span></a>{% else %}{{ s.announcement_text }}{% endif %}
    </div>
  {% endif %}

  <header class="yb-hdr-{{ uid }}">
    <div class="yb-bar-{{ uid }}">
      <button class="yb-left-{{ uid }}" data-yb-burger aria-label="Open menu">
        <svg viewBox="0 0 24 16"><path d="M0 1h24M0 8h24M0 15h24"/></svg>
        <span class="yb-left-label-{{ uid }}">{{ s.menu_label }}</span>
      </button>

      <a class="yb-brand-{{ uid }}" href="{{ routes.root_url }}">
        {% if logo_light != blank %}
          <img class="yb-logo-light-{{ uid }}" src="{{ logo_light | image_url: width: 600 }}" alt="{{ shop.name | escape }}" width="{{ logo_light.width }}" height="{{ logo_light.height }}">
          <img class="yb-logo-dark-{{ uid }}" src="{{ logo_dark | image_url: width: 600 }}" alt="{{ shop.name | escape }}" width="{{ logo_dark.width }}" height="{{ logo_dark.height }}">
        {% else %}
          <span class="yb-brand-txt-{{ uid }}">{{ shop.name }}</span>
        {% endif %}
      </a>

      <div class="yb-right-{{ uid }}">
        {% if s.help_label != blank %}<a class="yb-cell-{{ uid }} yb-cell-hidem-{{ uid }}" href="{{ s.help_link | default: '#' }}">{{ s.help_label }}</a>{% endif %}
        {% if s.show_search %}<a class="yb-cell-{{ uid }} yb-cell-hidem-{{ uid }}" href="{{ routes.search_url }}" aria-label="Search"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></a>{% endif %}
        {% if s.show_account %}<a class="yb-cell-{{ uid }}" href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" aria-label="Account"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg></a>{% endif %}
        {% if s.show_cart %}<a class="yb-cell-{{ uid }}" href="{{ routes.cart_url }}" aria-label="Cart"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><path d="M6 7h12l-1 14H7L6 7Z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg><span class="yb-count-{{ uid }}" data-yb-count>{{ cart.item_count }}</span></a>{% endif %}
      </div>
    </div>
  </header>
</div>

{%- comment -%} spacer reserves layout space (inline fallback, refined by JS) {%- endcomment -%}
<div class="yb-spacer-{{ uid }}" data-yb-spacer style="height:{% if overlay %}44px{% else %}108px{% endif %}"></div>

{%- comment -%} menu drawer {%- endcomment -%}
<div class="yb-scrim-{{ uid }}" data-yb-scrim></div>
<nav class="yb-drawer-{{ uid }}" data-yb-drawer aria-label="Menu">
  <div class="yb-dhead-{{ uid }}">
    <span>{{ s.menu_label }}</span>
    <button class="yb-dx-{{ uid }}" data-yb-close aria-label="Close"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24" style="width:24px;height:24px"><path d="M6 6l12 12M18 6 6 18"/></svg></button>
  </div>
  {% for link in menu.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
    {% for child in link.links %}<a class="sub" href="{{ child.url }}">{{ child.title }}</a>{% endfor %}
  {% endfor %}
</nav>

<script>
(function(){
  var root=document.getElementById('shopify-section-{{ uid }}');
  if(!root) return;
  var top=root.querySelector('[data-yb-top]'), spacer=root.querySelector('[data-yb-spacer]');
  var ann=top.querySelector('.yb-ann-{{ uid }}'), hdr=top.querySelector('.yb-hdr-{{ uid }}');
  var overlay=top.getAttribute('data-overlay')==='1';
  function sizes(){
    var a=ann?ann.offsetHeight:0, h=hdr?hdr.offsetHeight:0;
    root.style.setProperty('--yb-h',(a+h)+'px');
    if(spacer) spacer.style.height=(overlay? a : a+h)+'px';
  }
  sizes(); addEventListener('resize',sizes); setTimeout(sizes,300);
  if(overlay){
    var os=function(){ var solid=scrollY>=40; top.classList.toggle('yb-solid',solid); };
    addEventListener('scroll',os,{passive:true}); os();
  }
  /* drawer */
  var scrim=root.querySelector('[data-yb-scrim]'), drawer=root.querySelector('[data-yb-drawer]');
  var open=function(){ scrim.classList.add('open'); drawer.classList.add('open'); };
  var close=function(){ scrim.classList.remove('open'); drawer.classList.remove('open'); };
  var b=root.querySelector('[data-yb-burger]'); if(b) b.onclick=open;
  var x=root.querySelector('[data-yb-close]'); if(x) x.onclick=close;
  if(scrim) scrim.onclick=close;
})();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "yumbud-header-section",
  "settings": [
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Text", "default": "First time trying YumBud? Get 15% off" },
    { "type": "url", "id": "announcement_link", "label": "Link" },
    { "type": "color", "id": "ann_bg", "label": "Background", "default": "#211D18" },
    { "type": "color", "id": "ann_text", "label": "Text colour", "default": "#EFE9E1" },
    { "type": "header", "content": "Menu (opens from the left)" },
    { "type": "text", "id": "menu_label", "label": "Trigger label", "default": "Shop & Learn" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo_light", "label": "Logo — over hero (use a light/white version)" },
    { "type": "image_picker", "id": "logo_dark", "label": "Logo — solid bar (use a dark version)" },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 20, "max": 64, "step": 2, "unit": "px", "default": 34 },
    { "type": "paragraph", "content": "Leave both logos empty to show your store name in italic serif (it adapts colour automatically)." },
    { "type": "header", "content": "Right side" },
    { "type": "text", "id": "help_label", "label": "Text link label", "default": "Help Center" },
    { "type": "url", "id": "help_link", "label": "Text link" },
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": false },
    { "type": "checkbox", "id": "show_account", "label": "Show account icon", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart icon", "default": true },
    { "type": "header", "content": "Style" },
    { "type": "checkbox", "id": "transparent_home", "label": "Transparent over homepage hero", "info": "Overlays the first section on the homepage and turns solid on scroll. Pair with a full-bleed image hero.", "default": true },
    { "type": "checkbox", "id": "show_dividers", "label": "Show hairline divider grid", "default": true },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Solid background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Solid text / icons", "default": "#2B2420" },
    { "type": "color", "id": "transparent_text_color", "label": "Text over hero (transparent state)", "info": "White by default for a dark image hero; set dark for a light hero.", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Cart count badge", "default": "#535B72" },
    { "type": "font_picker", "id": "heading_font", "label": "Logo / menu font", "default": "assistant_n4" }
  ]
}
{% endschema %}
