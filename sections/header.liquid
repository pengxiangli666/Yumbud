{%- comment -%}
  ============================================================
  YumBud · Header + Mega Menu  (Main menu + Learn menu integrated)
  ============================================================
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
{%- assign logo = s.logo_light -%}
{%- assign overlay = false -%}
{%- if s.transparent_home and request.page_type == 'index' -%}{%- assign overlay = true -%}{%- endif -%}
{%- assign main_menu = linklists[s.main_menu] -%}
{%- assign learn_menu = linklists[s.learn_menu] -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-tcolor:{{ s.transparent_text_color }};
    --yb-accent:{{ s.accent_color }}; --yb-ann-bg:{{ s.ann_bg }}; --yb-ann-fg:{{ s.ann_text }};
    --yb-feat-bg:{{ s.feature_bg }}; --yb-badge-bg:{{ s.badge_bg }};
    --yb-muted:{{ s.text_color }}99;
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
    --yb-ease:cubic-bezier(.22,.61,.36,1);
    --yb-line-solid:{{ s.text_color }}24; --yb-line-trans:{{ s.transparent_text_color }}3d;
  }
  .yb-top-{{ uid }}{ position:fixed; top:0; left:0; right:0; z-index:50; }
  .yb-ann-{{ uid }}{ background:var(--yb-ann-bg); color:var(--yb-ann-fg); text-align:center; font-size:11px; letter-spacing:.08em; padding:11px 16px; }
  .yb-ann-{{ uid }} a{ color:inherit; text-decoration:none; display:inline-flex; align-items:center; gap:8px; }
  .yb-ann-{{ uid }} a:hover{ text-decoration:underline; text-underline-offset:3px; }
  .yb-hdr-{{ uid }}{ color:var(--yb-tcolor); background:transparent; transition:background .4s var(--yb-ease),color .4s var(--yb-ease); position:relative; z-index:2; }
  .yb-bar-{{ uid }}{ display:grid; grid-template-columns:1fr auto 1fr; align-items:stretch; height:64px; }
  .yb-divided-{{ uid }} .yb-bar-{{ uid }}{ border-top:2px solid rgba(255,255,255,0.6); border-bottom:2px solid rgba(255,255,255,0.6); transition:border-color .4s var(--yb-ease); }
  .yb-trig-{{ uid }}{ display:flex; align-items:center; gap:13px; padding:0 28px; background:none; border:none; color:inherit; cursor:pointer; font-family:inherit; font-size:13px; letter-spacing:.04em; justify-self:start; }
  .yb-divided-{{ uid }} .yb-trig-{{ uid }}{ border-right:1px solid var(--yb-line-trans); transition:border-color .4s var(--yb-ease); }
  .yb-trig-{{ uid }} svg{ width:20px; height:15px; stroke:currentColor; stroke-width:1.5; fill:none; }
  .yb-trig-{{ uid }} .st{ display:flex; align-items:center; gap:13px; }
  .yb-trig-{{ uid }} .yb-to{ display:none; }
  .yb-brand-{{ uid }}{ justify-self:center; align-self:center; display:flex; align-items:center; color:inherit; }
  .yb-brand-{{ uid }} img{ height:{{ s.logo_height }}px; width:auto; display:block; }
  .yb-brand-txt-{{ uid }}{ font-family:var(--yb-serif); font-style:italic; font-size:30px; font-weight:500; color:inherit; }
  .yb-right-{{ uid }}{ justify-self:end; display:flex; align-items:stretch; }
  .yb-cell-{{ uid }}{ display:flex; align-items:center; gap:9px; padding:0 24px; color:inherit; position:relative; transition:opacity .3s; font-size:13px; letter-spacing:.04em; }
  .yb-cell-{{ uid }}:hover{ opacity:.62; }
  .yb-divided-{{ uid }} .yb-right-{{ uid }} .yb-cell-{{ uid }}{ border-left:1px solid var(--yb-line-trans); transition:border-color .4s var(--yb-ease); }
  .yb-ic-{{ uid }}{ width:19px; height:19px; stroke:currentColor; stroke-width:1.4; fill:none; }
  .yb-count-{{ uid }}{ position:absolute; top:12px; right:14px; background:var(--yb-accent); color:#fff; font-size:9px; font-weight:600; min-width:15px; height:15px; padding:0 3px; border-radius:9px; display:flex; align-items:center; justify-content:center; }
  .yb-top-{{ uid }}.yb-solid .yb-hdr-{{ uid }},.yb-top-{{ uid }}.yb-open .yb-hdr-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); }
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-bar-{{ uid }},.yb-top-{{ uid }}.yb-open.yb-divided-{{ uid }} .yb-bar-{{ uid }},
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-trig-{{ uid }},.yb-top-{{ uid }}.yb-open.yb-divided-{{ uid }} .yb-trig-{{ uid }},
  .yb-top-{{ uid }}.yb-solid.yb-divided-{{ uid }} .yb-right-{{ uid }} .yb-cell-{{ uid }},.yb-top-{{ uid }}.yb-open.yb-divided-{{ uid }} .yb-right-{{ uid }} .yb-cell-{{ uid }}{ border-color:var(--yb-line-solid); }
  .yb-top-{{ uid }}.yb-open .yb-trig-{{ uid }} .yb-tc{ display:none; }
  .yb-top-{{ uid }}.yb-open .yb-trig-{{ uid }} .yb-to{ display:flex; }
  .yb-mscrim-{{ uid }}{ position:fixed; inset:0; top:var(--yb-h,108px); background:rgba(33,29,24,.32); z-index:1; opacity:0; pointer-events:none; transition:.4s; }
  .yb-top-{{ uid }}.yb-open .yb-mscrim-{{ uid }}{ opacity:1; pointer-events:auto; }
  .yb-mega-{{ uid }}{ position:fixed; left:0; right:0; top:var(--yb-h,108px); z-index:2; background:var(--yb-bg); color:var(--yb-ink);
    border-bottom:1px solid var(--yb-line-solid); box-shadow:0 42px 60px -42px rgba(43,36,32,.4);
    opacity:0; transform:translateY(-12px); pointer-events:none; transition:.4s var(--yb-ease); }
  .yb-top-{{ uid }}.yb-open .yb-mega-{{ uid }}{ opacity:1; transform:none; pointer-events:auto; }
  .yb-mega-in-{{ uid }}{ display:grid; grid-template-columns:1.15fr 1.15fr 1fr; max-width:1600px; margin:0 auto; min-height:430px; }
  .yb-mega-in-{{ uid }}.nofeat{ grid-template-columns:1.2fr 1fr; }
  .yb-col-{{ uid }}{ padding:40px 48px; }
  .yb-col-{{ uid }}+.yb-col-{{ uid }}{ border-left:1px solid var(--yb-line-solid); }
  .yb-ct-{{ uid }}{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-ink); opacity:.55; margin-bottom:24px; }
  .yb-shop-{{ uid }} a{ display:flex; align-items:center; gap:18px; padding:11px 0; color:var(--yb-ink); }
  .yb-shop-{{ uid }} a .th{ width:54px; height:54px; border-radius:6px; background:#ECEAE3; object-fit:cover; flex:none; display:block; }
  .yb-shop-{{ uid }} a .nm{ font-size:18px; flex:1; }
  .yb-shop-{{ uid }} a:hover .nm{ text-decoration:underline; text-underline-offset:3px; }
  .yb-badge-{{ uid }}{ font-size:10px; letter-spacing:.04em; background:var(--yb-badge-bg); color:#fff; padding:5px 12px; border-radius:30px; white-space:nowrap; }
  .yb-learn-{{ uid }}{ display:grid; grid-template-columns:repeat({{ s.learn_columns }},1fr); gap:6px 30px; align-content:start; }
  .yb-learn-{{ uid }} a{ font-size:18px; color:var(--yb-ink); padding:11px 0; }
  .yb-learn-{{ uid }} a:hover{ text-decoration:underline; text-underline-offset:3px; }
  .yb-feat-{{ uid }}{ background:var(--yb-feat-bg); padding:40px 48px; border-left:1px solid var(--yb-line-solid); }
  .yb-feat-{{ uid }} .stars{ color:var(--yb-ink); letter-spacing:3px; font-size:15px; margin:4px 0 18px; }
  .yb-feat-{{ uid }} .q{ font-size:16px; line-height:1.62; color:var(--yb-ink); }
  .yb-feat-{{ uid }} .meta{ display:flex; justify-content:space-between; margin-top:26px; font-size:13px; color:var(--yb-muted); }
  @media (max-width:860px){
    .yb-bar-{{ uid }}{ grid-template-columns:auto 1fr auto; height:56px; }
    .yb-trig-{{ uid }}{ padding:0 18px; } .yb-left-label-{{ uid }}{ display:none; }
    .yb-cell-{{ uid }}{ padding:0 14px; } .yb-cell-hidem-{{ uid }}{ display:none; } .yb-count-{{ uid }}{ right:6px; }
    .yb-mega-{{ uid }}{ bottom:0; height:calc(100% - var(--yb-h,100px)); overflow-y:auto; }
    .yb-mega-in-{{ uid }},.yb-mega-in-{{ uid }}.nofeat{ grid-template-columns:1fr; min-height:0; }
    .yb-col-{{ uid }}+.yb-col-{{ uid }},.yb-feat-{{ uid }}{ border-left:none; border-top:1px solid var(--yb-line-solid); }
    .yb-col-{{ uid }},.yb-feat-{{ uid }}{ padding:28px 24px; }
  }
</style>

<div class="yb-top-{{ uid }} {% if s.show_dividers %}yb-divided-{{ uid }}{% endif %} {% unless overlay %}yb-solid{% endunless %}"
     data-yb-top data-overlay="{% if overlay %}1{% else %}0{% endif %}">
  {% if s.show_announcement and s.announcement_text != blank %}
    <div class="yb-ann-{{ uid }}">{% if s.announcement_link != blank %}<a href="{{ s.announcement_link }}">{{ s.announcement_text }} <span>&rarr;</span></a>{% else %}{{ s.announcement_text }}{% endif %}</div>
  {% endif %}

  <header class="yb-hdr-{{ uid }}">
    <div class="yb-bar-{{ uid }}">
      <button class="yb-trig-{{ uid }}" data-yb-trigger aria-label="Open menu" aria-expanded="false">
        <span class="st yb-tc"><svg viewBox="0 0 24 16"><path d="M0 1h24M0 8h24M0 15h24"/></svg><span class="yb-left-label-{{ uid }}">{{ s.menu_label }}</span></span>
        <span class="st yb-to"><svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6 6 18"/></svg><span class="yb-left-label-{{ uid }}">{{ s.close_label }}</span></span>
      </button>

      <a class="yb-brand-{{ uid }}" href="{{ routes.root_url }}">
        {% if logo != blank %}
          <img src="{{ logo | image_url: width: 600 }}" alt="{{ shop.name | escape }}" width="{{ logo.width }}" height="{{ logo.height }}">
        {% else %}<span class="yb-brand-txt-{{ uid }}">{{ shop.name }}</span>{% endif %}
      </a>

      <div class="yb-right-{{ uid }}">
        {% if s.help_label != blank %}<a class="yb-cell-{{ uid }} yb-cell-hidem-{{ uid }}" href="{{ s.help_link | default: '#' }}">{{ s.help_label }}</a>{% endif %}
        {% if s.show_search %}<a class="yb-cell-{{ uid }} yb-cell-hidem-{{ uid }}" href="{{ routes.search_url }}" aria-label="Search"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></a>{% endif %}
        {% if s.show_account %}<a class="yb-cell-{{ uid }}" href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" aria-label="Account"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg></a>{% endif %}
        {% if s.show_cart %}<a class="yb-cell-{{ uid }}" href="{{ routes.cart_url }}" aria-label="Cart"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24" fill="none"><path d="M3 4h2l2.5 12h11l2-8H7"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg><span class="yb-count-{{ uid }}" data-yb-count>{{ cart.item_count }}</span></a>{% endif %}
      </div>
    </div>
  </header>

  <div class="yb-mscrim-{{ uid }}" data-yb-mscrim></div>

  <div class="yb-mega-{{ uid }}" data-yb-mega>
    <div class="yb-mega-in-{{ uid }} {% unless s.feature_enabled %}nofeat{% endunless %}">
      <div class="yb-col-{{ uid }}">
        {% if s.shop_heading != blank %}<div class="yb-ct-{{ uid }}">{{ s.shop_heading }}</div>{% endif %}
        <div class="yb-shop-{{ uid }}">
          {% if main_menu.links.size > 0 %}
            {% for link in main_menu.links %}
              <a href="{{ link.url }}">
                {% if link.object.featured_image != blank %}
                  <img class="th" src="{{ link.object.featured_image | image_url: width: 160 }}" alt="" width="54" height="54">
                {% elsif link.object.image != blank %}
                  <img class="th" src="{{ link.object.image | image_url: width: 160 }}" alt="" width="54" height="54">
                {% else %}
                  <span class="th"></span>
                {% endif %}
                <span class="nm">{{ link.title }}</span>
              </a>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <div class="yb-col-{{ uid }}">
        {% if s.learn_heading != blank %}<div class="yb-ct-{{ uid }}">{{ s.learn_heading }}</div>{% endif %}
        <div class="yb-learn-{{ uid }}">
          {% if learn_menu.links.size > 0 %}
            {% for link in learn_menu.links %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      {% if s.feature_enabled %}
        <div class="yb-feat-{{ uid }}">
          {% if s.feature_heading != blank %}<div class="yb-ct-{{ uid }}">{{ s.feature_heading }}</div>{% endif %}
          {% if s.feature_stars %}<div class="stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>{% endif %}
          {% if s.feature_text != blank %}<p class="q">{{ s.feature_text }}</p>{% endif %}
          {% if s.feature_author != blank or s.feature_date != blank %}<div class="meta"><span>{{ s.feature_author }}</span><span>{{ s.feature_date }}</span></div>{% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<div class="yb-spacer-{{ uid }}" data-yb-spacer style="height:{% if overlay %}44px{% else %}108px{% endif %}"></div>

<script>
(function(){
  var root=document.getElementById('shopify-section-{{ uid }}');
  if(!root) return;
  var top=root.querySelector('[data-yb-top]'), spacer=root.querySelector('[data-yb-spacer]');
  var ann=top.querySelector('.yb-ann-{{ uid }}'), hdr=top.querySelector('.yb-hdr-{{ uid }}');
  var overlay=top.getAttribute('data-overlay')==='1';
  function sizes(){ var a=ann?ann.offsetHeight:0,h=hdr?hdr.offsetHeight:0; root.style.setProperty('--yb-h',(a+h)+'px'); if(spacer) spacer.style.height=(overlay?a:a+h)+'px'; }
  sizes(); addEventListener('resize',sizes); setTimeout(sizes,300);
  if(overlay){ var os=function(){ top.classList.toggle('yb-solid',scrollY>=40); }; addEventListener('scroll',os,{passive:true}); os(); }
  var trig=root.querySelector('[data-yb-trigger]'), msc=root.querySelector('[data-yb-mscrim]');
  function openM(o){ top.classList.toggle('yb-open',o); if(trig) trig.setAttribute('aria-expanded',o?'true':'false'); document.body.style.overflow=o?'hidden':''; }
  if(trig) trig.onclick=function(){ openM(!top.classList.contains('yb-open')); };
  if(msc) msc.onclick=function(){ openM(false); };
  addEventListener('keydown',function(e){ if(e.key==='Escape') openM(false); });
})();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "yumbud-header-section",
  "settings": [
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Text", "default": "First time trying YumBud? Get 15% off" },
    { "type": "url", "id": "announcement_link", "label": "Link" },
    { "type": "color", "id": "ann_bg", "label": "Background", "default": "#211D18" },
    { "type": "color", "id": "ann_text", "label": "Text colour", "default": "#EFE9E1" },
    { "type": "header", "content": "Menu trigger (left)" },
    { "type": "text", "id": "menu_label", "label": "Open label", "default": "Shop & Learn" },
    { "type": "text", "id": "close_label", "label": "Close label", "default": "Close" },
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo_light", "label": "Logo" },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 20, "max": 64, "step": 2, "unit": "px", "default": 34 },
    { "type": "paragraph", "content": "Leave empty to show the store name as text instead." },
    { "type": "header", "content": "Right side" },
    { "type": "text", "id": "help_label", "label": "Text link label", "default": "Help Center" },
    { "type": "url", "id": "help_link", "label": "Text link" },
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": false },
    { "type": "checkbox", "id": "show_account", "label": "Show account icon", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart icon", "default": true },
    { "type": "header", "content": "Mega menu — Shop column" },
    { "type": "link_list", "id": "main_menu", "label": "Shop menu (links from Content > Menus)", "default": "main-menu" },
    { "type": "text", "id": "shop_heading", "label": "Left column title", "default": "Shop" },
    { "type": "color", "id": "badge_bg", "label": "Shop badge colour", "default": "#2E3D2A" },
    { "type": "header", "content": "Mega menu — Learn column" },
    { "type": "link_list", "id": "learn_menu", "label": "Learn menu (links from Content > Menus)" },
    { "type": "text", "id": "learn_heading", "label": "Middle column title", "default": "Learn" },
    { "type": "range", "id": "learn_columns", "label": "Middle column — link columns", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "header", "content": "Mega menu — featured column" },
    { "type": "checkbox", "id": "feature_enabled", "label": "Show featured column", "default": true },
    { "type": "text", "id": "feature_heading", "label": "Heading", "default": "Reviews" },
    { "type": "checkbox", "id": "feature_stars", "label": "Show 5 stars", "default": true },
    { "type": "textarea", "id": "feature_text", "label": "Quote / text", "default": "Treats can be such a hassle. My dog loses her mind for these and I love that I can actually read every ingredient." },
    { "type": "text", "id": "feature_author", "label": "Author", "default": "Maria F." },
    { "type": "text", "id": "feature_date", "label": "Date / detail", "default": "Verified buyer" },
    { "type": "color", "id": "feature_bg", "label": "Featured background", "default": "#F6F1E4" },
    { "type": "header", "content": "Style" },
    { "type": "checkbox", "id": "transparent_home", "label": "Transparent over homepage hero", "info": "Pair with a full-bleed image hero; turns solid on scroll.", "default": true },
    { "type": "checkbox", "id": "show_dividers", "label": "Show hairline divider grid in bar", "default": true },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Solid background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Solid text / icons", "default": "#2B2420" },
    { "type": "color", "id": "transparent_text_color", "label": "Text over hero (transparent)", "info": "White over a dark hero; dark over a light hero.", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Cart count badge", "default": "#535B72" },
    { "type": "font_picker", "id": "heading_font", "label": "Logo / mega-menu font", "default": "assistant_n4" }
  ],
  "presets": [
    { "name": "Header" }
  ]
}
{% endschema %}