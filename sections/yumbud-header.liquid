{%- comment -%}
  ============================================================
  YumBud · Header  (custom header for Dawn / any OS2.0 theme)
  Flairy-style split navigation: links left + centre logo +
  links right + search/account/cart icons. Transparent over the
  hero on the homepage, turns solid on scroll. Sticky. Dropdowns
  from your real Shopify menus. Mobile burger + slide-in drawer.

  INSTALL ON DAWN (recommended, simplest):
  1. Online Store > Themes > ⋯ > Edit code
  2. Open  sections/header.liquid
  3. Select ALL of its contents and COPY them into a scratch file
     first (so you can revert), then DELETE and paste THIS whole
     file in its place. Save.
  4. Customize > click the Header > pick your menus, logo, colours.
  (If your theme still shows a separate announcement bar, hide it —
   this header has its own, toggle below.)
  ============================================================
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}
{%- assign menu_left = s.menu_left -%}
{%- assign menu_right = s.menu_right -%}
{%- assign is_home = false -%}
{%- if request.page_type == 'index' -%}{%- assign is_home = true -%}{%- endif -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-tcolor:{{ s.transparent_text_color }};
    --yb-accent:{{ s.accent_color }}; --yb-line:{{ s.text_color }}1f; --yb-cream:#FAF8F3;
    --yb-ann-bg:{{ s.ann_bg }}; --yb-ann-fg:{{ s.ann_text }};
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
    --yb-ease:cubic-bezier(.22,.61,.36,1);
  }
  /* announcement */
  .yb-ann-{{ uid }}{ background:var(--yb-ann-bg); color:var(--yb-ann-fg); text-align:center;
    font-size:10.5px; letter-spacing:.24em; text-transform:uppercase; padding:9px 16px; font-weight:400; position:relative; z-index:60; }
  .yb-ann-{{ uid }} a{ color:inherit; text-decoration:underline; text-underline-offset:3px; }
  /* header shell */
  .yb-hdr-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); border-bottom:1px solid var(--yb-line);
    transition:background .45s var(--yb-ease),color .45s var(--yb-ease),border-color .45s var(--yb-ease); }
  {% if s.sticky %}.yb-hdr-{{ uid }}{ position:sticky; top:0; z-index:50; }{% endif %}
  .yb-hdr-{{ uid }}.yb-transparent{ background:transparent; color:var(--yb-tcolor); border-color:transparent; }
  {% if s.transparent_home and is_home %}
    /* pull the page up under the transparent header */
    #shopify-section-{{ uid }}{ position:relative; z-index:50; }
    #shopify-section-{{ uid }}+*{ margin-top:calc(-1 * var(--yb-h, 76px)); }
  {% endif %}
  .yb-in-{{ uid }}{ display:grid; grid-template-columns:1fr auto 1fr; align-items:center; gap:24px;
    max-width:1360px; margin:0 auto; padding:18px 40px; }
  /* nav */
  .yb-nav-{{ uid }}{ display:flex; align-items:center; gap:30px; }
  .yb-nav-{{ uid }}.right{ justify-content:flex-end; }
  .yb-navlink-{{ uid }}{ font-size:12.5px; letter-spacing:.1em; text-transform:uppercase; font-weight:500;
    color:inherit; background:none; border:none; cursor:pointer; display:inline-flex; align-items:center; gap:6px;
    padding:6px 0; position:relative; font-family:inherit; }
  .yb-navlink-{{ uid }}::after{ content:""; position:absolute; left:0; bottom:0; width:0; height:1px; background:currentColor; transition:.35s var(--yb-ease); }
  .yb-navitem-{{ uid }}:hover .yb-navlink-{{ uid }}::after,.yb-navlink-{{ uid }}:hover::after{ width:100%; }
  .yb-caret-{{ uid }}{ width:0; height:0; border-left:3.5px solid transparent; border-right:3.5px solid transparent; border-top:4px solid currentColor; opacity:.7; transition:transform .3s; }
  .yb-navitem-{{ uid }}{ position:relative; }
  .yb-dd-{{ uid }}{ position:absolute; top:100%; left:50%; transform:translateX(-50%) translateY(8px); min-width:200px;
    background:var(--yb-bg); color:var(--yb-ink); border:1px solid var(--yb-line); border-radius:4px;
    box-shadow:0 30px 60px -34px rgba(43,36,32,.45); padding:10px; opacity:0; pointer-events:none; transition:.28s var(--yb-ease); z-index:70; }
  .yb-navitem-{{ uid }}:hover .yb-dd-{{ uid }},.yb-navitem-{{ uid }}.open .yb-dd-{{ uid }}{ opacity:1; pointer-events:auto; transform:translateX(-50%) translateY(4px); }
  .yb-dd-{{ uid }} a{ display:block; font-size:13px; letter-spacing:.02em; color:var(--yb-ink); padding:9px 12px; border-radius:3px; transition:.2s; }
  .yb-dd-{{ uid }} a:hover{ background:var(--yb-cream); }
  /* logo */
  .yb-brand-{{ uid }}{ justify-self:center; display:flex; align-items:center; }
  .yb-brand-{{ uid }} img{ height:{{ s.logo_height }}px; width:auto; display:block; }
  .yb-brand-txt-{{ uid }}{ font-family:var(--yb-serif); font-size:26px; font-weight:500; letter-spacing:.02em; color:inherit; }
  /* tools */
  .yb-tools-{{ uid }}{ display:flex; align-items:center; gap:20px; margin-left:22px; }
  .yb-tools-{{ uid }} a{ color:inherit; display:flex; align-items:center; position:relative; transition:opacity .3s; }
  .yb-tools-{{ uid }} a:hover{ opacity:.62; }
  .yb-ic-{{ uid }}{ width:19px; height:19px; stroke:currentColor; stroke-width:1.4; fill:none; }
  .yb-count-{{ uid }}{ position:absolute; top:-7px; right:-9px; background:var(--yb-accent); color:#fff; font-size:9px; font-weight:600;
    min-width:15px; height:15px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
  /* burger (mobile) */
  .yb-burger-{{ uid }}{ display:none; background:none; border:none; color:inherit; cursor:pointer; }
  /* drawer */
  .yb-scrim-{{ uid }}{ position:fixed; inset:0; background:rgba(33,29,24,.4); backdrop-filter:blur(3px); z-index:80; opacity:0; pointer-events:none; transition:.4s; }
  .yb-scrim-{{ uid }}.open{ opacity:1; pointer-events:auto; }
  .yb-drawer-{{ uid }}{ position:fixed; top:0; left:0; height:100%; width:330px; max-width:86vw; background:var(--yb-bg); color:var(--yb-ink);
    z-index:81; transform:translateX(-100%); transition:.5s var(--yb-ease); padding:84px 30px 30px; overflow-y:auto;
    box-shadow:30px 0 80px -40px rgba(0,0,0,.4); }
  .yb-drawer-{{ uid }}.open{ transform:none; }
  .yb-drawer-{{ uid }} a{ display:block; font-family:var(--yb-serif); font-size:26px; font-weight:500; color:var(--yb-ink); padding:11px 0; border-bottom:1px solid var(--yb-line); }
  .yb-drawer-{{ uid }} a.sub{ font-family:inherit; font-size:15px; padding:8px 0 8px 14px; color:var(--yb-ink); opacity:.8; border-bottom:1px solid {{ s.text_color }}0d; }
  .yb-dx-{{ uid }}{ position:absolute; top:24px; right:26px; background:none; border:none; color:inherit; cursor:pointer; }
  @media (max-width:900px){
    .yb-in-{{ uid }}{ grid-template-columns:auto 1fr auto; padding:14px 22px; }
    .yb-nav-{{ uid }}{ display:none; }
    .yb-burger-{{ uid }}{ display:flex; }
    .yb-brand-{{ uid }}{ justify-self:start; margin-left:10px; }
    .yb-tools-{{ uid }}{ gap:16px; margin-left:0; }
    .yb-tools-{{ uid }} .yb-hidem{ display:none; }
  }
</style>

{% if s.show_announcement and s.announcement_text != blank %}
  <div class="yb-ann-{{ uid }}">
    {% if s.announcement_link != blank %}<a href="{{ s.announcement_link }}">{{ s.announcement_text }}</a>{% else %}{{ s.announcement_text }}{% endif %}
  </div>
{% endif %}

<header class="yb-hdr-{{ uid }} {% if s.transparent_home and is_home %}yb-transparent{% endif %}" data-yb-header data-transparent="{% if s.transparent_home and is_home %}1{% else %}0{% endif %}">
  <div class="yb-in-{{ uid }}">

    <button class="yb-burger-{{ uid }}" data-yb-burger aria-label="Menu">
      <svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </button>

    <nav class="yb-nav-{{ uid }} left">
      {% for link in menu_left.links %}
        {% if link.links.size > 0 %}
          <div class="yb-navitem-{{ uid }}" data-yb-dd>
            <button class="yb-navlink-{{ uid }}">{{ link.title }} <span class="yb-caret-{{ uid }}"></span></button>
            <div class="yb-dd-{{ uid }}">{% for child in link.links %}<a href="{{ child.url }}">{{ child.title }}</a>{% endfor %}</div>
          </div>
        {% else %}
          <a class="yb-navlink-{{ uid }}" href="{{ link.url }}">{{ link.title }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <a class="yb-brand-{{ uid }}" href="{{ routes.root_url }}">
      {% if s.logo != blank %}
        <img src="{{ s.logo | image_url: width: 600 }}" alt="{{ shop.name | escape }}" width="{{ s.logo.width }}" height="{{ s.logo.height }}">
      {% else %}
        <span class="yb-brand-txt-{{ uid }}">{{ shop.name }}</span>
      {% endif %}
    </a>

    <nav class="yb-nav-{{ uid }} right">
      {% for link in menu_right.links %}
        {% if link.links.size > 0 %}
          <div class="yb-navitem-{{ uid }}" data-yb-dd>
            <button class="yb-navlink-{{ uid }}">{{ link.title }} <span class="yb-caret-{{ uid }}"></span></button>
            <div class="yb-dd-{{ uid }}">{% for child in link.links %}<a href="{{ child.url }}">{{ child.title }}</a>{% endfor %}</div>
          </div>
        {% else %}
          <a class="yb-navlink-{{ uid }}" href="{{ link.url }}">{{ link.title }}</a>
        {% endif %}
      {% endfor %}

      <span class="yb-tools-{{ uid }}">
        {% if s.show_search %}<a href="{{ routes.search_url }}" class="yb-hidem" aria-label="Search"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></a>{% endif %}
        {% if s.show_account %}<a href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}" class="yb-hidem" aria-label="Account"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg></a>{% endif %}
        {% if s.show_cart %}<a href="{{ routes.cart_url }}" aria-label="Cart"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24"><path d="M6 7h12l-1 14H7L6 7Z"/><path d="M9 7a3 3 0 0 1 6 0"/></svg><span class="yb-count-{{ uid }}" data-yb-count>{{ cart.item_count }}</span></a>{% endif %}
      </span>
    </nav>
  </div>
</header>

{%- comment -%} mobile drawer {%- endcomment -%}
<div class="yb-scrim-{{ uid }}" data-yb-scrim></div>
<nav class="yb-drawer-{{ uid }}" data-yb-drawer aria-label="Menu">
  <button class="yb-dx-{{ uid }}" data-yb-close aria-label="Close"><svg class="yb-ic-{{ uid }}" viewBox="0 0 24 24" style="width:24px;height:24px"><path d="M6 6l12 12M18 6 6 18"/></svg></button>
  {% for link in menu_left.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
    {% for child in link.links %}<a class="sub" href="{{ child.url }}">{{ child.title }}</a>{% endfor %}
  {% endfor %}
  {% for link in menu_right.links %}
    <a href="{{ link.url }}">{{ link.title }}</a>
    {% for child in link.links %}<a class="sub" href="{{ child.url }}">{{ child.title }}</a>{% endfor %}
  {% endfor %}
</nav>

<script>
(function(){
  var root=document.getElementById('shopify-section-{{ uid }}');
  if(!root) return;
  var hdr=root.querySelector('[data-yb-header]');
  /* expose header height so the page can tuck under a transparent header */
  function setH(){ if(hdr) root.style.setProperty('--yb-h', hdr.offsetHeight+'px'); }
  setH(); addEventListener('resize',setH);
  /* transparent -> solid on scroll (homepage only) */
  if(hdr && hdr.getAttribute('data-transparent')==='1'){
    var onScroll=function(){ hdr.classList.toggle('yb-transparent', scrollY < 40); };
    addEventListener('scroll',onScroll,{passive:true}); onScroll();
  }
  /* dropdowns: click toggle (touch friendly) */
  root.querySelectorAll('[data-yb-dd]').forEach(function(it){
    var btn=it.querySelector('button');
    if(btn) btn.addEventListener('click',function(e){ e.preventDefault(); it.classList.toggle('open'); });
  });
  document.addEventListener('click',function(e){ if(!e.target.closest('[data-yb-dd]')) root.querySelectorAll('[data-yb-dd].open').forEach(function(i){i.classList.remove('open');}); });
  /* mobile drawer */
  var scrim=root.querySelector('[data-yb-scrim]'), drawer=root.querySelector('[data-yb-drawer]');
  var open=function(){ scrim.classList.add('open'); drawer.classList.add('open'); };
  var close=function(){ scrim.classList.remove('open'); drawer.classList.remove('open'); };
  var b=root.querySelector('[data-yb-burger]'); if(b) b.onclick=open;
  var x=root.querySelector('[data-yb-close]'); if(x) x.onclick=close;
  if(scrim) scrim.onclick=close;
})();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "yumbud-header-section",
  "settings": [
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement bar", "default": true },
    { "type": "text", "id": "announcement_text", "label": "Announcement text", "default": "Complimentary shipping over $48 · Small batch, made in California · Cancel or skip anytime" },
    { "type": "url", "id": "announcement_link", "label": "Announcement link" },
    { "type": "color", "id": "ann_bg", "label": "Announcement background", "default": "#211D18" },
    { "type": "color", "id": "ann_text", "label": "Announcement text colour", "default": "#D9D3C8" },
    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo (uses store name if empty)" },
    { "type": "range", "id": "logo_height", "label": "Logo height", "min": 22, "max": 72, "step": 2, "unit": "px", "default": 44 },
    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu_left", "label": "Left menu", "default": "main-menu" },
    { "type": "link_list", "id": "menu_right", "label": "Right menu", "info": "Create a second menu in Content > Menus for the right side." },
    { "type": "header", "content": "Icons" },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
    { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart", "default": true },
    { "type": "header", "content": "Behaviour" },
    { "type": "checkbox", "id": "sticky", "label": "Sticky on scroll", "default": true },
    { "type": "checkbox", "id": "transparent_home", "label": "Transparent over homepage hero", "info": "Sits over the first section on the homepage, turns solid on scroll.", "default": true },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Solid background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Solid text / icons", "default": "#2B2420" },
    { "type": "color", "id": "transparent_text_color", "label": "Text over hero (transparent state)", "info": "Use a light colour over a dark hero image, dark over a light hero.", "default": "#2B2420" },
    { "type": "color", "id": "accent_color", "label": "Cart count badge", "default": "#535B72" },
    { "type": "font_picker", "id": "heading_font", "label": "Logo / dropdown font", "default": "assistant_n4" }
  ]
}
{% endschema %}
