{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --yb-bg:{{ s.bg_color }}; --yb-ink:{{ s.text_color }}; --yb-muted:{{ s.muted_color }};
    --yb-accent:{{ s.accent_color }};
    --yb-serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  .yb-pk-{{ uid }}{ background:var(--yb-bg); color:var(--yb-ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  .yb-pk-wrap-{{ uid }}{ max-width:1180px; margin:0 auto; padding:0 40px; }
  .yb-pk-head-{{ uid }}{ text-align:center; margin-bottom:50px; }
  .yb-pk-eyebrow-{{ uid }}{ font-size:11px; letter-spacing:.22em; text-transform:uppercase; color:var(--yb-muted); margin-bottom:14px; }
  .yb-pk-{{ uid }} h2{ font-family:var(--yb-serif); font-size:clamp(28px,3.6vw,42px); font-weight:500; line-height:1.1; }
  .yb-pk-grid-{{ uid }}{ display:grid; grid-template-columns:repeat({{ s.columns }},1fr); gap:30px; }
  .yb-pk-item-{{ uid }}{ text-align:center; padding:20px; }
  .yb-pk-item-{{ uid }} .ic{ width:54px; height:54px; margin:0 auto 18px; display:flex; align-items:center; justify-content:center; color:var(--yb-accent); }
  .yb-pk-item-{{ uid }} .ic svg{ width:100%; height:100%; stroke:currentColor; stroke-width:1.2; fill:none; }
  .yb-pk-item-{{ uid }} h3{ font-family:var(--yb-serif); font-size:20px; font-weight:500; margin-bottom:8px; }
  .yb-pk-item-{{ uid }} p{ font-size:14px; color:var(--yb-muted); line-height:1.6; }
  @media (max-width:760px){
    .yb-pk-grid-{{ uid }}{ grid-template-columns:1fr 1fr; gap:20px; }
    .yb-pk-wrap-{{ uid }}{ padding:0 24px; }
  }
  @media (max-width:480px){ .yb-pk-grid-{{ uid }}{ grid-template-columns:1fr; } }
</style>

<section class="yb-pk-{{ uid }}">
  <div class="yb-pk-wrap-{{ uid }}">
    {% if s.eyebrow != blank or s.heading != blank %}
      <div class="yb-pk-head-{{ uid }}">
        {% if s.eyebrow != blank %}<div class="yb-pk-eyebrow-{{ uid }}">{{ s.eyebrow }}</div>{% endif %}
        {% if s.heading != blank %}<h2>{{ s.heading }}</h2>{% endif %}
      </div>
    {% endif %}
    <div class="yb-pk-grid-{{ uid }}">
      {% for block in section.blocks %}
        <div class="yb-pk-item-{{ uid }}" {{ block.shopify_attributes }}>
          <div class="ic">
            {% case block.settings.icon %}
              {% when 'truck' %}<svg viewBox="0 0 32 32"><rect x="2" y="9" width="18" height="14"/><path d="M20 13h6l4 5v5h-10"/><circle cx="9" cy="25" r="2.5"/><circle cx="24" cy="25" r="2.5"/></svg>
              {% when 'calendar' %}<svg viewBox="0 0 32 32"><rect x="5" y="7" width="22" height="20" rx="2"/><path d="M5 13h22M11 4v6M21 4v6"/></svg>
              {% when 'star' %}<svg viewBox="0 0 32 32"><path d="m16 4 3.7 7.7 8.3 1.2-6 5.9 1.4 8.3L16 23l-7.4 4 1.4-8.3-6-5.9 8.3-1.2L16 4Z"/></svg>
              {% when 'heart' %}<svg viewBox="0 0 32 32"><path d="M16 28C9 22 6 17 6 12a6 6 0 0 1 10-4 6 6 0 0 1 10 4c0 5-3 10-10 16Z"/></svg>
              {% when 'check' %}<svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="12"/><path d="M11 16l3.4 3.4L21 12"/></svg>
              {% when 'leaf' %}<svg viewBox="0 0 32 32"><path d="M7 25c0-10 8-18 18-18 0 10-8 18-18 18Z"/><path d="M7 25c4-7 9-11 14-13"/></svg>
              {% when 'gift' %}<svg viewBox="0 0 32 32"><rect x="4" y="12" width="24" height="16"/><path d="M4 18h24M16 12v16M11 12a4 4 0 1 1 5-5 4 4 0 1 1 5 5"/></svg>
              {% else %}<svg viewBox="0 0 32 32"><circle cx="16" cy="16" r="12"/></svg>
            {% endcase %}
          </div>
          {% if block.settings.title != blank %}<h3>{{ block.settings.title }}</h3>{% endif %}
          {% if block.settings.text != blank %}<p>{{ block.settings.text }}</p>{% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "YumBud · Perks",
  "tag": "section",
  "class": "yumbud-perks",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Header" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Subscribe" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "The perks." },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "label": "Columns", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#FAF8F3" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#8C8578" },
    { "type": "color", "id": "accent_color", "label": "Icon colour", "default": "#535B72" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 72 }
  ],
  "blocks": [
    { "type": "perk", "name": "Perk", "settings": [
      { "type": "select", "id": "icon", "label": "Icon", "options": [
        { "value": "truck", "label": "Truck (shipping)" },
        { "value": "calendar", "label": "Calendar" },
        { "value": "star", "label": "Star" },
        { "value": "heart", "label": "Heart" },
        { "value": "check", "label": "Check" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "gift", "label": "Gift" }
      ], "default": "truck" },
      { "type": "text", "id": "title", "label": "Title", "default": "Free shipping" },
      { "type": "text", "id": "text", "label": "Text", "default": "On orders over $48." }
    ] }
  ],
  "presets": [
    { "name": "YumBud · Perks", "blocks": [
      { "type": "perk", "settings": { "icon": "truck", "title": "Free shipping", "text": "On every subscription order." } },
      { "type": "perk", "settings": { "icon": "calendar", "title": "Skip or swap", "text": "Adjust your delivery anytime." } },
      { "type": "perk", "settings": { "icon": "star", "title": "Save 20%", "text": "Member pricing on every bag." } },
      { "type": "perk", "settings": { "icon": "heart", "title": "Cancel anytime", "text": "No contracts, no fees." } }
    ] }
  ]
}
{% endschema %}