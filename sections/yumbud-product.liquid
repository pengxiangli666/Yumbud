{%- comment -%}
  YumBud · Product Content v2
  Adds ingredients_grid block (horizontal scroll cards) to replace split layout.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --bg:{{ s.bg_color }}; --ink:{{ s.text_color }}; --muted:{{ s.muted_color }};
    --accent:{{ s.accent_color }}; --line:{{ s.text_color }}1f; --card:{{ s.card_color }};
    --serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  #shopify-section-{{ uid }} .yb-pc{ background:var(--bg); color:var(--ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  #shopify-section-{{ uid }} *{ box-sizing:border-box; }
  #shopify-section-{{ uid }} img{ display:block; max-width:100%; }
  #shopify-section-{{ uid }} .yb-in{ max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px); }
  #shopify-section-{{ uid }} .yb-content{ display:flex; flex-direction:column; gap:clamp(48px,7vw,96px); }
  #shopify-section-{{ uid }} .yb-sec-h{ font-family:var(--serif); font-weight:500; line-height:1.1; font-size:clamp(24px,3vw,38px); margin:0 0 20px; }
  #shopify-section-{{ uid }} .yb-rte{ font-size:16px; line-height:1.7; color:var(--muted); }
  #shopify-section-{{ uid }} .yb-rte p{ margin:0 0 1em; }
  #shopify-section-{{ uid }} .yb-rte p:last-child{ margin-bottom:0; }

  /* highlights */
  #shopify-section-{{ uid }} .yb-hl-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(18px,2.4vw,32px); }
  #shopify-section-{{ uid }} .yb-hl{ text-align:center; }
  #shopify-section-{{ uid }} .yb-hl svg{ width:34px; height:34px; stroke:var(--accent); stroke-width:1.4; fill:none; margin:0 auto 14px; }
  #shopify-section-{{ uid }} .yb-hl .lab{ font-family:var(--serif); font-size:19px; margin-bottom:5px; }
  #shopify-section-{{ uid }} .yb-hl .txt{ font-size:14px; line-height:1.55; color:var(--muted); }

  /* ingredients grid */
  #shopify-section-{{ uid }} .yb-ig-header{ display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:28px; }
  #shopify-section-{{ uid }} .yb-ig-header-left{ max-width:420px; }
  #shopify-section-{{ uid }} .yb-ig-header-left h2{ margin-bottom:10px; }
  #shopify-section-{{ uid }} .yb-ig-header-left p{ font-size:15px; color:var(--muted); line-height:1.6; margin:0; }
  #shopify-section-{{ uid }} .yb-ig-viewall{ font-size:13px; color:var(--ink); text-decoration:underline; text-underline-offset:3px; white-space:nowrap; }
  #shopify-section-{{ uid }} .yb-ig-scroller{ display:flex; gap:16px; overflow-x:auto; scroll-snap-type:x mandatory; scrollbar-width:none; padding-bottom:4px; cursor:grab; }
  #shopify-section-{{ uid }} .yb-ig-scroller::-webkit-scrollbar{ display:none; }
  #shopify-section-{{ uid }} .yb-ig-scroller.dragging{ cursor:grabbing; scroll-snap-type:none; }
  #shopify-section-{{ uid }} .yb-ig-card{ flex:none; width:{{ s.card_width }}px; scroll-snap-align:start; position:relative; border-radius:{{ s.card_radius }}px; overflow:hidden; background:var(--card); aspect-ratio:3/4; border:{{ s.card_border_width }}px solid {{ s.card_border_color }}; }
  #shopify-section-{{ uid }} .yb-ig-card img{ width:100%; height:100%; object-fit:cover; transition:transform .5s cubic-bezier(.22,.61,.36,1); }
  #shopify-section-{{ uid }} .yb-ig-card:hover img{ transform:scale(1.04); }
  #shopify-section-{{ uid }} .yb-ig-label{ position:absolute; bottom:0; left:0; right:0; padding:12px 16px; background:{{ s.label_bg }}; display:flex; justify-content:space-between; align-items:center; opacity:0; transform:translateY(6px); transition:opacity .3s ease, transform .3s ease; }
  #shopify-section-{{ uid }} .yb-ig-card:hover .yb-ig-label{ opacity:1; transform:translateY(0); }
  #shopify-section-{{ uid }} .yb-ig-label span{ font-size:{{ s.label_font_size }}px; letter-spacing:.08em; text-transform:uppercase; color:{{ s.label_text_color }}; font-weight:500; }
  #shopify-section-{{ uid }} .yb-ig-plus{ width:28px; height:28px; border-radius:50%; background:var(--accent); color:#fff; display:flex; align-items:center; justify-content:center; font-size:16px; flex:none; }

  /* storage */
  #shopify-section-{{ uid }} .yb-storage{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(28px,4vw,56px); align-items:start; }
  #shopify-section-{{ uid }} .yb-storage-icon{ font-size:48px; margin-bottom:16px; }
  #shopify-section-{{ uid }} .yb-storage-tips{ display:flex; flex-direction:column; gap:14px; margin-top:20px; }
  #shopify-section-{{ uid }} .yb-storage-tip{ display:flex; align-items:center; gap:14px; font-size:14px; color:var(--muted); line-height:1.5; }
  #shopify-section-{{ uid }} .yb-storage-tip .tip-icon{ font-size:36px; flex:none; }
  #shopify-section-{{ uid }} .yb-storage-tip .tip-img{ width:40px; height:40px; object-fit:contain; flex:none; }    

  /* nutrition */
  #shopify-section-{{ uid }} .yb-nutr{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(28px,4vw,56px); align-items:end; }
  #shopify-section-{{ uid }} .yb-nutr > div:last-child{ position:static; }
  #shopify-section-{{ uid }} .yb-nutr-table{ margin-top:8px; display:flex; flex-direction:column; gap:18px; }
  #shopify-section-{{ uid }} .yb-nutr-row{ display:flex; flex-direction:column; gap:8px; }
  #shopify-section-{{ uid }} .yb-nutr-row .nr-top{ display:flex; justify-content:space-between; align-items:baseline; }
  #shopify-section-{{ uid }} .yb-nutr-row .nr-label{ font-size:14px; color:var(--ink); font-weight:400; }
  #shopify-section-{{ uid }} .yb-nutr-row .nr-val{ font-size:14px; font-weight:600; color:var(--ink); }
  #shopify-section-{{ uid }} .yb-nutr-bar-wrap{ height:10px; background:{{ s.bar_track_color | default: '#E5E1D7' }}; border-radius:30px; overflow:hidden; }
  #shopify-section-{{ uid }} .yb-nutr-bar{ height:100%; border-radius:30px; transition:width .8s cubic-bezier(.22,.61,.36,1); }
  #shopify-section-{{ uid }} .yb-nutr-bar.c1{ background:#5C6B4A; }
  #shopify-section-{{ uid }} .yb-nutr-bar.c2{ background:#A07040; }
  #shopify-section-{{ uid }} .yb-nutr-bar.c3{ background:#8C9E7A; }
  #shopify-section-{{ uid }} .yb-nutr-bar.c4{ background:#B89A60; }
  #shopify-section-{{ uid }} .yb-nutr-bar.c5{ background:#6B7F5A; }
  #shopify-section-{{ uid }} .yb-nutr-bar.c6{ background:#9E8060; }
  #shopify-section-{{ uid }} .yb-nutr-calorie{ padding:24px 28px; background:var(--card); border-radius:12px; margin-bottom:16px; }
  #shopify-section-{{ uid }} .yb-nutr-calorie .cal-title{ font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--muted); margin-bottom:10px; }
  #shopify-section-{{ uid }} .yb-nutr-calorie .cal-val{ font-family:var(--serif); font-size:36px; font-weight:500; line-height:1; margin-bottom:4px; color:var(--ink); }
  #shopify-section-{{ uid }} .yb-nutr-calorie .cal-sub{ font-size:12px; color:var(--muted); }
  #shopify-section-{{ uid }} .yb-nutr-badge-box{ padding:20px 24px; background:var(--ink); border-radius:12px; display:flex; align-items:flex-start; gap:14px; }
  #shopify-section-{{ uid }} .yb-nutr-badge-box svg{ width:32px; height:32px; flex:none; stroke:#FAF8F3; stroke-width:1.4; fill:none; margin-top:2px; }
  #shopify-section-{{ uid }} .yb-nutr-badge-box .bb-title{ font-size:15px; font-weight:500; color:#FAF8F3; margin-bottom:4px; }
  #shopify-section-{{ uid }} .yb-nutr-badge-box .bb-sub{ font-size:12px; color:rgba(250,248,243,0.6); line-height:1.5; }

  @media (max-width:860px){
    #shopify-section-{{ uid }} .yb-storage{ grid-template-columns:1fr; }
    #shopify-section-{{ uid }} .yb-nutr{ grid-template-columns:1fr; }
  }
  #shopify-section-{{ uid }} .yb-split{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(28px,4vw,56px); align-items:center; }
  #shopify-section-{{ uid }} .yb-split.img-right .yb-split-media{ order:2; }
  #shopify-section-{{ uid }} .yb-split-media img{ width:100%; border-radius:6px; aspect-ratio:4/3; object-fit:cover; background:var(--card); }

  /* accordion */
  #shopify-section-{{ uid }} .yb-faq-item{ border-bottom:1px solid var(--line); }
  #shopify-section-{{ uid }} .yb-faq-item:first-child{ border-top:1px solid var(--line); }
  #shopify-section-{{ uid }} .yb-faq-item summary{ list-style:none; cursor:pointer; padding:20px 40px 20px 0; position:relative; font-size:17px; font-family:var(--serif); }
  #shopify-section-{{ uid }} .yb-faq-item summary::-webkit-details-marker{ display:none; }
  #shopify-section-{{ uid }} .yb-faq-item summary::after{ content:"+"; position:absolute; right:4px; top:50%; transform:translateY(-50%); font-size:20px; color:var(--muted); }
  #shopify-section-{{ uid }} .yb-faq-item[open] summary::after{ content:"\2212"; }
  #shopify-section-{{ uid }} .yb-faq-a{ padding:0 0 22px; font-size:14px; line-height:1.7; color:var(--muted); max-width:70ch; }

  @media (max-width:860px){
    #shopify-section-{{ uid }} .yb-hl-grid{ grid-template-columns:1fr 1fr; gap:28px; }
    #shopify-section-{{ uid }} .yb-split{ grid-template-columns:1fr; gap:22px; }
    #shopify-section-{{ uid }} .yb-split.img-right .yb-split-media{ order:0; }
    #shopify-section-{{ uid }} .yb-ig-header{ flex-direction:column; align-items:flex-start; gap:10px; }
    #shopify-section-{{ uid }} .yb-ig-card{ width:220px; }
  }
</style>

<div class="yb-pc">
  <div class="yb-in">
    {% if section.blocks.size > 0 %}
      <div class="yb-content">
        {% for block in section.blocks %}
          {% case block.type %}

          {% when 'highlights' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              <div class="yb-hl-grid">
                {% for i in (1..4) %}
                  {%- assign lk = 'item_' | append: i | append: '_label' -%}
                  {%- assign tk = 'item_' | append: i | append: '_text' -%}
                  {%- assign ik = 'item_' | append: i | append: '_icon' -%}
                  {% if block.settings[lk] != blank %}
                    <div class="yb-hl">
                      {% assign ic = block.settings[ik] %}
                      {% case ic %}
                        {% when 'leaf' %}<svg viewBox="0 0 24 24"><path d="M4 20c0-9 7-16 16-16 0 9-7 16-16 16Z"/><path d="M4 20C8 14 13 11 18 9"/></svg>
                        {% when 'heart' %}<svg viewBox="0 0 24 24"><path d="M12 21S4 14.5 4 8.8A4.3 4.3 0 0 1 12 6a4.3 4.3 0 0 1 8 2.8C20 14.5 12 21 12 21Z"/></svg>
                        {% when 'paw' %}<svg viewBox="0 0 24 24"><circle cx="6" cy="10" r="2"/><circle cx="10" cy="6" r="2"/><circle cx="14" cy="6" r="2"/><circle cx="18" cy="10" r="2"/><path d="M8 17a4 4 0 0 1 8 0c0 2-2 3-4 3s-4-1-4-3Z"/></svg>
                        {% when 'bowl' %}<svg viewBox="0 0 24 24"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M12 11c0-3 2-5 4-5"/></svg>
                        {% when 'shield' %}<svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6l7-3Z"/></svg>
                        {% when 'no' %}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M6 6l12 12"/></svg>
                        {% else %}<svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                      {% endcase %}
                      <div class="lab">{{ block.settings[lk] }}</div>
                      {% if block.settings[tk] != blank %}<div class="txt">{{ block.settings[tk] }}</div>{% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </section>

          {% when 'ingredients_grid' %}
            <section {{ block.shopify_attributes }}>
              <div class="yb-ig-header">
                <div class="yb-ig-header-left">
                  {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
                  {% if block.settings.subheading != blank %}<p>{{ block.settings.subheading }}</p>{% endif %}
                </div>
                {% if block.settings.viewall_label != blank and block.settings.viewall_link != blank %}
                  <a class="yb-ig-viewall" href="{{ block.settings.viewall_link }}">{{ block.settings.viewall_label }}</a>
                {% endif %}
              </div>
              <div class="yb-ig-scroller" data-yb-ig-scroller>
                {% for i in (1..8) %}
                  {%- assign imgk = 'ing_' | append: i | append: '_image' -%}
                  {%- assign namek = 'ing_' | append: i | append: '_name' -%}
                  {% if block.settings[imgk] != blank %}
                    <div class="yb-ig-card">
                      <img src="{{ block.settings[imgk] | image_url: width: 800 }}" alt="{{ block.settings[namek] | escape }}" loading="lazy">
                      {% if block.settings[namek] != blank %}
                        <div class="yb-ig-label">
                          <span>{{ block.settings[namek] }}</span>
                          <div class="yb-ig-plus">+</div>
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </section>

          {% when 'ingredients' %}
            <section class="yb-split {% if block.settings.image_position == 'right' %}img-right{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}<div class="yb-split-media"><img src="{{ block.settings.image | image_url: width: 1200 }}" alt="" loading="lazy"></div>{% endif %}
              <div>
                {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
                {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
              </div>
            </section>

          {% when 'feeding' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
            </section>

          {% when 'text' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
            </section>

          {% when 'storage' %}
            <section {{ block.shopify_attributes }}>
              <div class="yb-storage">
                <div>
                  {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
                  {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
                </div>
                <div>
                  <div class="yb-storage-tips">
                    {% for i in (1..4) %}
                      {%- assign ik = 'tip_' | append: i | append: '_icon' -%}
                      {%- assign tk = 'tip_' | append: i | append: '_text' -%}
                      {%- assign imgk = 'tip_' | append: i | append: '_image' -%}
                      {% if block.settings[tk] != blank %}
                        <div class="yb-storage-tip">
                          {% if block.settings[imgk] != blank %}
                            <img class="tip-img" src="{{ block.settings[imgk] | image_url: width: 48 }}" alt="" loading="lazy">
                          {% elsif block.settings[ik] != blank %}
                            <span class="tip-icon">{{ block.settings[ik] }}</span>
                          {% else %}
                            <span class="tip-icon">📦</span>
                          {% endif %}
                          <span>{{ block.settings[tk] }}</span>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </section>

          {% when 'nutrition' %}
            {%- assign bar_colors = 'c1,c2,c3,c4,c5,c6' | split: ',' -%}
            <section {{ block.shopify_attributes }}>
              <div class="yb-nutr">
                <div>
                  {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
                  {% if block.settings.subheading != blank %}<div class="yb-rte" style="margin-bottom:24px;">{{ block.settings.subheading }}</div>{% endif %}
                  <div class="yb-nutr-table">
                    {% for i in (1..6) %}
                      {%- assign lk = 'nutr_' | append: i | append: '_label' -%}
                      {%- assign vk = 'nutr_' | append: i | append: '_value' -%}
                      {%- assign pk = 'nutr_' | append: i | append: '_pct' -%}
                      {%- assign ci = forloop.index0 -%}
                      {%- assign color_class = bar_colors[ci] -%}
                      {% if block.settings[lk] != blank %}
                        <div class="yb-nutr-row">
                          <div class="nr-top">
                            <span class="nr-label">{{ block.settings[lk] }}</span>
                            <span class="nr-val">{{ block.settings[vk] }}</span>
                          </div>
                          <div class="yb-nutr-bar-wrap">
                            <div class="yb-nutr-bar {{ color_class }}" style="width:{{ block.settings[pk] | default: 50 }}%"></div>
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                  {% if block.settings.note != blank %}
                    <div class="yb-rte" style="margin-top:18px; font-size:12px;">{{ block.settings.note }}</div>
                  {% endif %}
                </div>
                <div>
                  {% if block.settings.calorie_title != blank %}
                    <div class="yb-nutr-calorie">
                      <div class="cal-title">{{ block.settings.calorie_title }}</div>
                      <div class="cal-val">{{ block.settings.calorie_val }}</div>
                      <div class="cal-sub">{{ block.settings.calorie_sub }}</div>
                    </div>
                  {% endif %}
                  <div class="yb-nutr-badge-box">
                    <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6l7-3Z"/><path d="M9 12l2 2 4-4"/></svg>
                    <div>
                      <div class="bb-title">{{ block.settings.badge_title | default: 'Clean. Simple. Honest.' }}</div>
                      <div class="bb-sub">{{ block.settings.badge_sub | default: 'Real ingredients with guaranteed nutrition you can trust.' }}</div>
                    </div>
                  </div>
                </div>
              </div>
            </section>

          {% when 'accordion' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              <div>
                {% for q in (1..5) %}
                  {%- assign qk = 'q_' | append: q -%}
                  {%- assign ak = 'a_' | append: q -%}
                  {% if block.settings[qk] != blank %}
                    <details class="yb-faq-item"><summary>{{ block.settings[qk] }}</summary><div class="yb-faq-a">{{ block.settings[ak] }}</div></details>
                  {% endif %}
                {% endfor %}
              </div>
            </section>

          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
document.querySelectorAll('[data-yb-ig-scroller]').forEach(function(el){
  var down=false, sx=0, sl=0, moved=0;
  el.addEventListener('pointerdown',function(e){ down=true; moved=0; sx=e.clientX; sl=el.scrollLeft; el.classList.add('dragging'); });
  el.addEventListener('pointermove',function(e){ if(!down) return; var d=e.clientX-sx; moved=Math.abs(d); el.scrollLeft=sl-d; });
  var up=function(){ down=false; el.classList.remove('dragging'); };
  el.addEventListener('pointerup',up);
  el.addEventListener('pointerleave',up);
});
</script>

{% schema %}
{
  "name": "YumBud · Product Content",
  "tag": "section",
  "class": "yumbud-product-content-section",
  "max_blocks": 12,
  "settings": [
    { "type": "range", "id": "card_width", "label": "Ingredient card width", "min": 180, "max": 360, "step": 10, "unit": "px", "default": 260 },
    { "type": "range", "id": "card_radius", "label": "Card corner radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 4 },
    { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#E5E1D7" },
    { "type": "range", "id": "card_border_width", "label": "Card border thickness", "min": 0, "max": 6, "step": 1, "unit": "px", "default": 1 },
    { "type": "header", "content": "Ingredient label" },
    { "type": "color", "id": "label_bg", "label": "Label background", "default": "rgba(0,0,0,0.55)", "info": "Use rgba for transparency, e.g. rgba(0,0,0,0.5)" },
    { "type": "color", "id": "label_text_color", "label": "Label text color", "default": "#FFFFFF" },
    { "type": "range", "id": "label_font_size", "label": "Label font size", "min": 9, "max": 18, "step": 1, "unit": "px", "default": 12 },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#574F46" },
    { "type": "color", "id": "accent_color", "label": "Accent / + button", "default": "#535B72" },
    { "type": "color", "id": "card_color", "label": "Card background", "default": "#ECEAE3" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 88 }
  ],
  "blocks": [
    {
      "type": "highlights",
      "name": "Benefit highlights",
