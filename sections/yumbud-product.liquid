{%- comment -%}
  YumBud · Product Content
  Content blocks below the buy box: highlights, ingredients,
  feeding guide, text, accordion. Place this section below
  "YumBud · Product Top" with any other sections in between.
{%- endcomment -%}
{%- assign s = section.settings -%}
{%- assign uid = section.id -%}

<style>
  #shopify-section-{{ uid }}{
    --bg:{{ s.bg_color }}; --ink:{{ s.text_color }}; --muted:{{ s.muted_color }};
    --accent:{{ s.accent_color }}; --line:{{ s.text_color }}1f; --card:{{ s.card_color }};
    --serif:{{ s.heading_font.family }},{{ s.heading_font.fallback_families }};
  }
  #shopify-section-{{ uid }} .yb-pc{ background:var(--bg); color:var(--ink); padding:{{ s.padding_top }}px 0 {{ s.padding_bottom }}px; }
  #shopify-section-{{ uid }} *{ box-sizing:border-box; }
  #shopify-section-{{ uid }} img{ display:block; max-width:100%; }
  #shopify-section-{{ uid }} .yb-in{ max-width:1240px; margin:0 auto; padding:0 clamp(20px,5vw,56px); }
  #shopify-section-{{ uid }} .yb-content{ display:flex; flex-direction:column; gap:clamp(48px,7vw,96px); }
  #shopify-section-{{ uid }} .yb-sec-h{ font-family:var(--serif); font-weight:500; line-height:1.1; font-size:clamp(24px,3vw,38px); margin:0 0 20px; }
  #shopify-section-{{ uid }} .yb-rte{ font-size:16px; line-height:1.7; color:var(--muted); }
  #shopify-section-{{ uid }} .yb-rte p{ margin:0 0 1em; } #shopify-section-{{ uid }} .yb-rte p:last-child{ margin-bottom:0; }

  /* highlights */
  #shopify-section-{{ uid }} .yb-hl-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:clamp(18px,2.4vw,32px); }
  #shopify-section-{{ uid }} .yb-hl{ text-align:center; }
  #shopify-section-{{ uid }} .yb-hl svg{ width:34px; height:34px; stroke:var(--accent); stroke-width:1.4; fill:none; margin:0 auto 14px; }
  #shopify-section-{{ uid }} .yb-hl .lab{ font-family:var(--serif); font-size:19px; margin-bottom:5px; }
  #shopify-section-{{ uid }} .yb-hl .txt{ font-size:14px; line-height:1.55; color:var(--muted); }

  /* split */
  #shopify-section-{{ uid }} .yb-split{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(28px,4vw,56px); align-items:center; }
  #shopify-section-{{ uid }} .yb-split.img-right .yb-split-media{ order:2; }
  #shopify-section-{{ uid }} .yb-split-media img{ width:100%; border-radius:6px; aspect-ratio:4/3; object-fit:cover; background:var(--card); }

  /* accordion */
  #shopify-section-{{ uid }} .yb-faq-item{ border-bottom:1px solid var(--line); }
  #shopify-section-{{ uid }} .yb-faq-item:first-child{ border-top:1px solid var(--line); }
  #shopify-section-{{ uid }} .yb-faq-item summary{ list-style:none; cursor:pointer; padding:20px 40px 20px 0; position:relative; font-size:17px; font-family:var(--serif); }
  #shopify-section-{{ uid }} .yb-faq-item summary::-webkit-details-marker{ display:none; }
  #shopify-section-{{ uid }} .yb-faq-item summary::after{ content:"+"; position:absolute; right:4px; top:50%; transform:translateY(-50%); font-size:20px; color:var(--muted); }
  #shopify-section-{{ uid }} .yb-faq-item[open] summary::after{ content:"\2212"; }
  #shopify-section-{{ uid }} .yb-faq-a{ padding:0 0 22px; font-size:14px; line-height:1.7; color:var(--muted); max-width:70ch; }

  @media (max-width:860px){
    #shopify-section-{{ uid }} .yb-hl-grid{ grid-template-columns:1fr 1fr; gap:28px; }
    #shopify-section-{{ uid }} .yb-split{ grid-template-columns:1fr; gap:22px; }
    #shopify-section-{{ uid }} .yb-split.img-right .yb-split-media{ order:0; }
  }
</style>

<div class="yb-pc">
  <div class="yb-in">
    {% if section.blocks.size > 0 %}
      <div class="yb-content">
        {% for block in section.blocks %}
          {% case block.type %}

          {% when 'highlights' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              <div class="yb-hl-grid">
                {% for i in (1..4) %}
                  {%- assign lk = 'item_' | append: i | append: '_label' -%}
                  {%- assign tk = 'item_' | append: i | append: '_text' -%}
                  {%- assign ik = 'item_' | append: i | append: '_icon' -%}
                  {% if block.settings[lk] != blank %}
                    <div class="yb-hl">
                      {% assign ic = block.settings[ik] %}
                      {% case ic %}
                        {% when 'leaf' %}<svg viewBox="0 0 24 24"><path d="M4 20c0-9 7-16 16-16 0 9-7 16-16 16Z"/><path d="M4 20C8 14 13 11 18 9"/></svg>
                        {% when 'heart' %}<svg viewBox="0 0 24 24"><path d="M12 21S4 14.5 4 8.8A4.3 4.3 0 0 1 12 6a4.3 4.3 0 0 1 8 2.8C20 14.5 12 21 12 21Z"/></svg>
                        {% when 'paw' %}<svg viewBox="0 0 24 24"><circle cx="6" cy="10" r="2"/><circle cx="10" cy="6" r="2"/><circle cx="14" cy="6" r="2"/><circle cx="18" cy="10" r="2"/><path d="M8 17a4 4 0 0 1 8 0c0 2-2 3-4 3s-4-1-4-3Z"/></svg>
                        {% when 'bowl' %}<svg viewBox="0 0 24 24"><path d="M3 11h18a9 9 0 0 1-18 0Z"/><path d="M12 11c0-3 2-5 4-5"/></svg>
                        {% when 'shield' %}<svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3 8-7 10-4-2-7-5-7-10V6l7-3Z"/></svg>
                        {% when 'no' %}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M6 6l12 12"/></svg>
                        {% else %}<svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg>
                      {% endcase %}
                      <div class="lab">{{ block.settings[lk] }}</div>
                      {% if block.settings[tk] != blank %}<div class="txt">{{ block.settings[tk] }}</div>{% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            </section>

          {% when 'ingredients' %}
            <section class="yb-split {% if block.settings.image_position == 'right' %}img-right{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}<div class="yb-split-media"><img src="{{ block.settings.image | image_url: width: 1200 }}" alt="" loading="lazy"></div>{% endif %}
              <div>
                {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
                {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
              </div>
            </section>

          {% when 'feeding' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
            </section>

          {% when 'text' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              {% if block.settings.body != blank %}<div class="yb-rte">{{ block.settings.body }}</div>{% endif %}
            </section>

          {% when 'accordion' %}
            <section {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}<h2 class="yb-sec-h">{{ block.settings.heading }}</h2>{% endif %}
              <div>
                {% for q in (1..5) %}
                  {%- assign qk = 'q_' | append: q -%}
                  {%- assign ak = 'a_' | append: q -%}
                  {% if block.settings[qk] != blank %}
                    <details class="yb-faq-item"><summary>{{ block.settings[qk] }}</summary><div class="yb-faq-a">{{ block.settings[ak] }}</div></details>
                  {% endif %}
                {% endfor %}
              </div>
            </section>

          {% endcase %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "YumBud · Product Content",
  "tag": "section",
  "class": "yumbud-product-content-section",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#F2F1EC" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#2B2420" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#574F46" },
    { "type": "color", "id": "accent_color", "label": "Accent", "default": "#535B72" },
    { "type": "color", "id": "card_color", "label": "Image placeholder", "default": "#ECEAE3" },
    { "type": "font_picker", "id": "heading_font", "label": "Heading font", "default": "assistant_n4" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "default": 88 }
  ],
  "blocks": [
    {
      "type": "highlights",
      "name": "Benefit highlights",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Why dogs love it" },
        { "type": "select", "id": "item_1_icon", "label": "Icon 1", "options": [ { "value": "leaf", "label": "Leaf" }, { "value": "heart", "label": "Heart" }, { "value": "paw", "label": "Paw" }, { "value": "bowl", "label": "Bowl" }, { "value": "shield", "label": "Shield" }, { "value": "no", "label": "No / cross" }, { "value": "check", "label": "Check" } ], "default": "leaf" },
        { "type": "text", "id": "item_1_label", "label": "Item 1 label", "default": "Whole-food" },
        { "type": "text", "id": "item_1_text", "label": "Item 1 text", "default": "Real produce & protein you can name." },
        { "type": "select", "id": "item_2_icon", "label": "Icon 2", "options": [ { "value": "leaf", "label": "Leaf" }, { "value": "heart", "label": "Heart" }, { "value": "paw", "label": "Paw" }, { "value": "bowl", "label": "Bowl" }, { "value": "shield", "label": "Shield" }, { "value": "no", "label": "No / cross" }, { "value": "check", "label": "Check" } ], "default": "no" },
        { "type": "text", "id": "item_2_label", "label": "Item 2 label", "default": "No nasties" },
        { "type": "text", "id": "item_2_text", "label": "Item 2 text", "default": "No fillers, dyes or mystery powders." },
        { "type": "select", "id": "item_3_icon", "label": "Icon 3", "options": [ { "value": "leaf", "label": "Leaf" }, { "value": "heart", "label": "Heart" }, { "value": "paw", "label": "Paw" }, { "value": "bowl", "label": "Bowl" }, { "value": "shield", "label": "Shield" }, { "value": "no", "label": "No / cross" }, { "value": "check", "label": "Check" } ], "default": "shield" },
        { "type": "text", "id": "item_3_label", "label": "Item 3 label", "default": "Vet-formulated" },
        { "type": "text", "id": "item_3_text", "label": "Item 3 text", "default": "Balanced by vets & pet nutritionists." },
        { "type": "select", "id": "item_4_icon", "label": "Icon 4", "options": [ { "value": "leaf", "label": "Leaf" }, { "value": "heart", "label": "Heart" }, { "value": "paw", "label": "Paw" }, { "value": "bowl", "label": "Bowl" }, { "value": "shield", "label": "Shield" }, { "value": "no", "label": "No / cross" }, { "value": "check", "label": "Check" } ], "default": "bowl" },
        { "type": "text", "id": "item_4_label", "label": "Item 4 label", "default": "Made in LA" },
        { "type": "text", "id": "item_4_text", "label": "Item 4 text", "default": "Small-batch, food-grade facility." }
      ]
    },
    {
      "type": "ingredients",
      "name": "What's inside",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "What's inside" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Whole foods you'd recognise — apples, garden herbs, leafy greens, and a little real chicken.</p>" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "select", "id": "image_position", "label": "Image position", "options": [ { "value": "left", "label": "Left" }, { "value": "right", "label": "Right" } ], "default": "left" }
      ]
    },
    {
      "type": "feeding",
      "name": "How to serve",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "How to serve" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Feed as a treat, or crumble over your dog's regular food for a tasty boost.</p>" }
      ]
    },
    {
      "type": "text",
      "name": "Text block",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Our promise" },
        { "type": "richtext", "id": "body", "label": "Body", "default": "<p>If we wouldn't eat it, we don't make it.</p>" }
      ]
    },
    {
      "type": "accordion",
      "name": "FAQ / details",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Good to know" },
        { "type": "text", "id": "q_1", "label": "Q1", "default": "Are these a complete meal?" },
        { "type": "richtext", "id": "a_1", "label": "A1", "default": "<p>No — these are treats, meant to complement a complete, balanced diet.</p>" },
        { "type": "text", "id": "q_2", "label": "Q2", "default": "What's the ingredient list?" },
        { "type": "richtext", "id": "a_2", "label": "A2", "default": "<p>Whole foods you'd recognise — see "What's inside."</p>" },
        { "type": "text", "id": "q_3", "label": "Q3", "default": "How should I store them?" },
        { "type": "richtext", "id": "a_3", "label": "A3" },
        { "type": "text", "id": "q_4", "label": "Q4" },
        { "type": "richtext", "id": "a_4", "label": "A4" },
        { "type": "text", "id": "q_5", "label": "Q5" },
        { "type": "richtext", "id": "a_5", "label": "A5" }
      ]
    }
  ],
  "presets": [
    {
      "name": "YumBud · Product Content",
      "blocks": [
        { "type": "highlights" },
        { "type": "ingredients" },
        { "type": "feeding" },
        { "type": "accordion" }
      ]
    }
  ]
}
{% endschema %}
